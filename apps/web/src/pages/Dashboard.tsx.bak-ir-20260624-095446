function KanbanPeek({ state }: { state: TasksState }) {
  const { list, loaded } = state;
  const navigate = useNavigate();

  // Bucket cards by Today / Overdue / Tomorrow.
  //   Overdue = bucket 'today' that's been sitting since before today's
  //             midnight (browser-local — Kevin is on Chicago time), OR a
  //             due_at in the past with status != done.
  //   Today   = bucket 'today' AND not overdue.
  //   Tomorrow = bucket 'tomorrow'.
  // Blocked/active/pending all count; done/failed/archived do not.
  const grouped: Record<'today'|'overdue'|'tomorrow', TaskRow[]> = useMemo(() => {
    const startOfToday = new Date();
    startOfToday.setHours(0, 0, 0, 0);
    const startMs = startOfToday.getTime();
    const acc = { today: [] as TaskRow[], overdue: [] as TaskRow[], tomorrow: [] as TaskRow[] };
    for (const t of list) {
      if (t.status === 'done' || t.status === 'failed') continue;
      // Overdue strictly = a due date before today. Creation time has no bearing
      // on which day-bucket a task belongs to (the old created_at heuristic was
      // shoving still-due-today tasks into Overdue).
      const dueOverdue = t.due_at !== null && Date.parse(t.due_at) < startMs;
      if (dueOverdue) {
        acc.overdue.push(t);
      } else if (t.bucket === 'today') {
        acc.today.push(t);
      } else if (t.bucket === 'tomorrow') {
        acc.tomorrow.push(t);
      }
    }
    for (const k of Object.keys(acc) as Array<keyof typeof acc>) {
      acc[k].sort((a, b) => b.updated_at.localeCompare(a.updated_at));
    }
    return acc;
  }, [list]);

  return (
    <Panel
      title="Task Board · Today"
      icon={<Columns3 size={14} />}
      accent="linear-gradient(135deg, #FF4D8D, #FF8A3D)"
      meta={
        <button
          type="button"
          onClick={() => navigate('/kanban')}
          className="flex items-center gap-1 px-2.5 py-1 text-[11px] rounded-md border border-sky-200 hover:bg-sky-50 transition-colors"
          style={{ color: '#F1F4FF' }}
        >
          Open board
          <ArrowRight className="w-2.5 h-2.5" aria-hidden />
        </button>
      }
    >
      <div className="grid grid-cols-3 gap-2.5 p-3" data-testid="kanban-peek">
        {PEEK_COLS.map((c) => {
          const colTasks = grouped[c.id];
          const cards = colTasks.slice(0, 5);
          return (
            <div key={c.id} data-kanban-column={c.id}>
              <div className="flex items-center gap-1.5 mb-2">
                <span
                  className="block w-1.5 h-1.5 rounded-[2px]"
                  style={{ background: c.hue, boxShadow: `0 0 8px ${c.hue}` }}
                />
                <span className="vs-mono text-[10px] tracking-[0.18em]" style={{ color: '#9AA8C2' }}>
                  {c.title}
                </span>
                <span className="vs-mono text-[10px] ml-auto" style={{ color: '#74849A' }}>
                  {colTasks.length}
                </span>
              </div>
              <div className="flex flex-col gap-1.5">
                {!loaded && (
                  <div className="text-[11px] italic" style={{ color: '#74849A' }}>loading…</div>
                )}
                {loaded && cards.length === 0 && (
                  <div className="text-[11px] italic" style={{ color: '#74849A' }}>none</div>
                )}
                {cards.map((k) => {
                  const due = formatDue(k.due_at);
                  return (
                    <div
                      key={k.id}
                      role="button"
                      tabIndex={0}
                      onClick={() => navigate('/kanban')}
                      className="relative p-2 rounded-md overflow-hidden cursor-pointer hover:bg-white/5 transition-colors"
                      style={{
                        background: '#181D3A',
                        border: '1px solid #232A4D',
                      }}
                    >
                      <div
                        aria-hidden
                        className="absolute top-0 bottom-0 left-0 w-[2px]"
                        style={{ background: c.hue, opacity: 0.7 }}
                      />
                      <div className="text-[11.5px] leading-snug ml-1.5 truncate" title={k.title} style={{ color: '#F1F4FF' }}>
                        {k.title}
                      </div>
                      <div className="flex items-center gap-1.5 mt-1.5 ml-1.5">
                        {k.assigned_agent ? (
                          <>
                            <AgentAvatar handle={k.assigned_agent} displayName={k.assigned_agent} size={16} />
                            <span
                              className="text-[10.5px] truncate"
                              style={{ color: '#9aa3b5' }}
                              title={k.assigned_agent}
                            >
                              {k.assigned_agent}
                            </span>
                          </>
                        ) : (
                          <>
                            <span
                              className="w-4 h-4 rounded-full inline-block"
                              style={{ background: 'rgba(14,165,233,0.14)' }}
                              aria-hidden
                            />
