        <span className="vs-mono text-[10px]" style={{ color: '#9AA8C2' }} data-testid="agent-roster-meta">
          COMING SOON
        </span>
      }
    >
      <div className="grid grid-cols-2 gap-2 p-2.5" data-testid="agent-roster-grid">
        {SLOTS.map((i) => (
          <div
            key={i}
            className="relative flex items-center gap-2.5 p-2 rounded-[10px] overflow-hidden"
            style={{ background: '#141937', border: '1px dashed #232A4D', opacity: 0.7 }}
          >
            <span className="w-7 h-7 rounded-full grid place-items-center flex-shrink-0" style={{ background: '#1B2147', color: '#74849A' }} aria-hidden>
              <Cpu size={14} />
            </span>
            <div className="flex-1 min-w-0">
              <div className="text-[12px] font-semibold truncate" style={{ color: '#C3CCE6' }}>Employee Agent</div>
              <div className="text-[10.5px] truncate" style={{ color: '#74849A' }}>reserved · coming soon</div>
            </div>
          </div>
        ))}
      </div>
    </Panel>
  );
}

function timeAgoIso(iso: string): string {
  try {
    const ms = Date.now() - new Date(iso).getTime();
    if (ms < 60_000) return 'just now';
    if (ms < 3_600_000) return `${Math.floor(ms / 60_000)}m`;
    if (ms < 86_400_000) return `${Math.floor(ms / 3_600_000)}h`;
    return `${Math.floor(ms / 86_400_000)}d`;
  } catch { return ''; }
}

function SlackAttentionPanel({ state }: { state: SlackAttentionState }) {
  const { list, loaded } = state;
  // Optimistic removal — drop from the visible list the moment the click
  // lands so Kevin doesn't think the button is broken while the 15s poll
  // catches up.
  const [hidden, setHidden] = useState<Set<string>>(new Set());
  const ack = (id: string, mode: 'ack' | 'dismiss') => {
    setHidden((prev) => {
      const next = new Set(prev);
      next.add(id);
      return next;
    });
    authedFetch(`api/slack/attention/${id}/${mode}`, { method: 'POST' })
      .then((r) => {
        // If the server rejected, un-hide so the user can retry
        if (!r.ok) {
          setHidden((prev) => {
            const next = new Set(prev);
            next.delete(id);
            return next;
          });
        }
      })
      .catch(() => {
        setHidden((prev) => {
          const next = new Set(prev);
          next.delete(id);
          return next;
        });
      });
  };
  const visible = list.filter((m) => !hidden.has(m.id));
  return (
    <Panel
      title="Slack"
      icon={<MessageSquare size={14} />}
      accent="linear-gradient(135deg, #0EA5E9, #7C3CFF)"
      meta={
        <div className="flex items-center gap-2 vs-mono text-[10px]" data-testid="slack-attn-meta">
          <span style={{ color: loaded && visible.length > 0 ? '#0EA5E9' : '#74849A' }}>
            {!loaded ? 'CONNECTING…' : visible.length === 0 ? 'CLEAR' : `${visible.length} OPEN`}
          </span>
        </div>
      }
    >
      <div data-testid="slack-attention-panel">
        {!loaded && (
          <div className="px-3.5 py-3 text-[12px] italic" style={{ color: '#74849A' }}>
            checking Slack…
          </div>
        )}
        {loaded && visible.length === 0 && (
          <div className="px-3.5 py-3 text-[12px]" style={{ color: '#74849A' }}>
            No DMs or @-mentions to handle. Quiet inbox.
          </div>
        )}
        {visible.slice(0, 6).map((m, i) => (
          <div
            key={m.id}
            className="flex items-start gap-2.5 px-3.5 py-2"
            data-slack-attn-item
            style={{
              borderBottom:
                i < Math.min(visible.length, 6) - 1
                  ? '1px solid rgba(216,228,240,0.85)'
                  : 'none',
            }}
          >
            <span
              className="block rounded-[2px] flex-shrink-0 mt-1"
              style={{ width: 3, height: 22, background: '#0EA5E9', boxShadow: '0 0 6px #0EA5E9' }}
            />
            <div className="flex-1 min-w-0">
              <div className="flex items-center gap-2">
                <span className="text-[12px] font-medium truncate" style={{ color: '#F1F4FF' }}>
                  {m.userName ?? m.userId ?? 'unknown'}
                </span>
                <span className="vs-mono text-[10px]" style={{ color: '#74849A' }}>
                  {m.reason ?? ''}
                </span>
              </div>
              <div className="text-[11.5px] truncate" style={{ color: '#9AA8C2' }} title={m.preview}>
                {m.preview || '(empty)'}
              </div>
              <div className="flex items-center gap-2 mt-1">
                {m.permalink && (
                  <a
                    href={m.permalink}
                    target="_blank"
                    rel="noreferrer"
                    className="vs-mono text-[10px]"
                    style={{ color: '#0EA5E9' }}
                  >
                    open ↗
                  </a>
                )}
                <button
                  onClick={() => ack(m.id, 'ack')}
                  className="vs-mono text-[10px]"
                  style={{ color: '#20B26B' }}
                >
                  ack
                </button>
                <button
                  onClick={() => ack(m.id, 'dismiss')}
                  className="vs-mono text-[10px]"
                  style={{ color: '#FF4D8D' }}
                >
                  dismiss
                </button>
              </div>
            </div>
            <span className="vs-mono text-[10px]" style={{ color: '#74849A' }}>
              {timeAgoIso(m.createdAt)}
            </span>
          </div>
        ))}
      </div>
    </Panel>
  );
}

function InboxPanel({ state }: { state: InboxState }) {
  const { list, loaded, email } = state;
  return (
    <Panel
      title="Inbox"
      icon={<Mail size={14} />}
      accent="linear-gradient(135deg, #20B26B, #0EA5E9)"
      meta={
        <div className="flex items-center gap-2 vs-mono text-[10px]" data-testid="inbox-meta">
          {email && (
            <span
              className="truncate max-w-[160px]"
              style={{ color: '#9AA8C2' }}
              title={email}
            >
              {email}
            </span>
          )}
          <span
            style={{ color: loaded && list.length > 0 ? '#20B26B' : '#74849A' }}
          >
            {!loaded ? 'LOADING…' : list.length === 0 ? 'CLEAR' : `${list.length} UNREAD`}
          </span>
        </div>
      }
    >
      <div data-testid="inbox-panel">
        {!loaded && (
          <div className="px-3.5 py-3 text-[12px] italic" style={{ color: '#74849A' }}>
            checking inbox…
          </div>
        )}
        {loaded && list.length === 0 && (
          <div className="px-3.5 py-3 text-[12px]" style={{ color: '#74849A' }}>
            No unread mail. Connect Gmail in Connectors if this is unexpected.
          </div>
        )}
        {list.slice(0, 5).map((m, i) => {
          const hue = inboxHue(m.id);
          return (
            <div
              key={m.id}
              className="flex items-center gap-2.5 px-3.5 py-2"
              data-inbox-item
              style={{
                borderBottom:
                  i < Math.min(list.length, 5) - 1
                    ? '1px solid rgba(216,228,240,0.85)'
                    : 'none',
              }}
            >
              <span
                className="block rounded-[2px] flex-shrink-0"
                style={{
                  width: 3,
                  height: 22,
                  background: hue,
                  boxShadow: `0 0 6px ${hue}`,
                }}
              />
              <div className="flex-1 min-w-0">
                <div className="text-[12px] font-medium truncate" style={{ color: '#F1F4FF' }}>
                  {senderName(m.sender)}
                </div>
                <div className="text-[11.5px] truncate" style={{ color: '#9AA8C2' }} title={m.subject}>
                  {m.subject || '(no subject)'}
                </div>
              </div>
              <span className="vs-mono text-[10px]" style={{ color: '#74849A' }}>
                {timeAgo(m.timestamp)}
              </span>
            </div>
          );
        })}
      </div>
    </Panel>
  );
}

function WhatsAppPanel({ state }: { state: WhatsAppState }) {
  const { list, loaded } = state;
  const navigate = useNavigate();
  const totalUnread = list.reduce((sum, t) => sum + t.unread_count, 0);

  return (
    <Panel
      title="WhatsApp"
      icon={<MessageSquare size={14} />}
      accent="linear-gradient(135deg, #25d366, #128C7E)"
      meta={
        <div className="flex items-center gap-2 vs-mono text-[10px]">
          <span style={{ color: loaded && totalUnread > 0 ? '#25d366' : '#74849A' }}>
            {!loaded ? 'LOADING…' : totalUnread === 0 ? 'CLEAR' : `${totalUnread} UNREAD`}
          </span>
        </div>
      }
    >
      <div>
        {!loaded && (
          <div className="px-3.5 py-3 text-[12px] italic" style={{ color: '#74849A' }}>
            checking messages…
          </div>
        )}
        {loaded && list.length === 0 && (
          <div className="px-3.5 py-3 text-[12px]" style={{ color: '#74849A' }}>
            No unread messages.
          </div>
        )}
        {list.slice(0, 5).map((thread, i) => (
          <div
            key={thread.chat_id}
            onClick={() => navigate('/whatsapp')}
            className="flex items-center gap-2.5 px-3.5 py-2 cursor-pointer hover:bg-sky-50 transition-colors"
            style={{
              borderBottom:
                i < Math.min(list.length, 5) - 1
                  ? '1px solid rgba(216,228,240,0.85)'
                  : 'none',
            }}
          >
            <span
              className="block rounded-[2px] flex-shrink-0"
              style={{
                width: 3,
                height: 22,
                background: '#25d366',
                boxShadow: '0 0 6px #25d366',
              }}
            />
            <div className="flex-1 min-w-0">
              <div className="text-[12px] font-medium truncate" style={{ color: '#F1F4FF' }}>
                {thread.display_name || thread.phone || 'Unknown'}
                {thread.is_group && ' (Group)'}
              </div>
              <div className="text-[11.5px] truncate" style={{ color: '#9AA8C2' }} title={thread.last_message_preview || ''}>
                {thread.last_message_preview || '(no preview)'}
              </div>
            </div>
            <div className="flex flex-col items-end gap-1">
              {thread.unread_count > 0 && (
                <span
                  className="px-1.5 py-0.5 rounded-full text-[10px] font-semibold"
                  style={{ background: '#25d366', color: '#FFFFFF' }}
                >
                  {thread.unread_count}
                </span>
              )}
              <span className="vs-mono text-[10px]" style={{ color: '#74849A' }}>
                {timeAgo(thread.last_message_at || '')}
              </span>
            </div>
          </div>
        ))}
      </div>
    </Panel>
  );
}

interface IntegrationStatus {
  id: string;
  name?: string;
  configured: boolean;
}

const CONNECTOR_HUES: Record<string, string> = {
  google:           '#ea4335',
  google_workspace: '#ea4335',
  workspace:        '#ea4335',
  n8n:              '#FF8A3D',
  airtable:         '#FF8A3D',
  notion:           '#182235',
  slack:            '#FF4D8D',
  telegram:         '#0EA5E9',
  make:             '#7C3CFF',
  stripe:           '#9d8bff',
  homeassistant:    '#20B26B',
  home_assistant:   '#20B26B',
  ha:               '#20B26B',
  gemini:           '#0EA5E9',
  github:           '#182235',
  youtube:          '#ff5c5c',
  spotify:          '#20B26B',
};

function hueFor(id: string): string {
  return CONNECTOR_HUES[id] ?? '#9AA8C2';
}

function ConnectionsGrid() {
  const [list, setList] = useState<IntegrationStatus[]>([]);
  useEffect(() => {
        authedFetch('api/connectors/integrations')
      .then((r) => (r.ok ? r.json() : []))
      .then((data: unknown) => {
        if (Array.isArray(data)) setList(data as IntegrationStatus[]);
      })
      .catch(() => { /* silent */ });
  }, []);

  const configured = list.filter((c) => c.configured).length;
  const slice = list.slice(0, 9);

  return (
    <Panel
      title="Connections"
      icon={<Orbit size={14} />}
      accent="linear-gradient(135deg, #FF4D8D, #FF8A3D)"
      meta={
        <span className="vs-mono text-[10px]" style={{ color: '#20B26B' }}>
          {configured}/{list.length || '—'} HEALTHY
        </span>
      }
    >
      <div className="grid grid-cols-3 gap-1.5 p-2.5">
        {slice.length === 0 && (
          <div className="col-span-3 px-2 py-3 text-[11px] text-center" style={{ color: '#74849A' }}>
            No connectors configured.
          </div>
        )}
        {slice.map((c) => (
          <div
            key={c.id}
            className="flex items-center gap-2 px-2.5 py-2 rounded-md"
            style={{
              background: 'rgba(255,255,255,0.86)',
              border: '1px solid rgba(216,228,240,0.95)',
            }}
          >
            <span
              className="block w-2 h-2 rounded-[2px]"
              style={{ background: hueFor(c.id), boxShadow: `0 0 6px ${hueFor(c.id)}99` }}
            />
            <span className="text-[11px] flex-1 truncate" style={{ color: '#F1F4FF' }}>
              {c.name ?? c.id}
            </span>
          </div>
        ))}
      </div>
    </Panel>
  );
}

/** Convert an ISO-or-date string to a fractional hour-of-day, or null. */
function isoToHour(iso: string): number | null {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.getHours() + d.getMinutes() / 60;
}

interface TimelineBlock {
  laneKey: string;
  label: string;
  hue: string;
  startH: number;
  endH: number;
  source: 'event' | 'task';
}

/**
 * Greedy pack overlapping blocks into vertical rows so nothing renders on
 * top of anything else. Returns each block annotated with its row index
 * and the total row count needed for the lane.
 *
 * Used by the timeline lanes (especially "You", which can have stacked
 * meetings) so a busy day grows downward instead of overlapping.
 */
function packBlocksIntoRows(blocks: TimelineBlock[]): {
  packed: Array<TimelineBlock & { row: number }>;
  rowCount: number;
} {
  const sorted = [...blocks].sort((a, b) => a.startH - b.startH || a.endH - b.endH);
  const rowEnds: number[] = []; // row index → end hour of last block placed
  const packed = sorted.map((b) => {
    let row = rowEnds.findIndex((end) => end <= b.startH);
    if (row === -1) {
      row = rowEnds.length;
      rowEnds.push(b.endH);
    } else {
      rowEnds[row] = b.endH;
    }
    return { ...b, row };
  });
  return { packed, rowCount: Math.max(1, rowEnds.length) };
}

interface TimelinePanelProps {
  calendar: CalendarState;
  tasks: TasksState;
  rascals: RascalsState;
}

function TimelinePanel({ calendar, tasks, rascals }: TimelinePanelProps) {
  // Visible window. Could be config later; design uses 8 AM - 5:30 PM.
  const startH = 8;
  const endH = 17.5;
  const hours = Array.from({ length: 10 }, (_, i) => startH + i);
  const pct = (h: number) => ((h - startH) / (endH - startH)) * 100;

  const today = new Date();
  const isToday = (iso: string | null): boolean => {
    if (!iso) return false;
    const d = new Date(iso);
    return (
      d.getFullYear() === today.getFullYear() &&
      d.getMonth() === today.getMonth() &&
      d.getDate() === today.getDate()
    );
  };

  // Build calendar blocks for the You lane. Skip all-day events from the
  // hour-axis; they show up in the lane label as a count instead.
  const youBlocks: TimelineBlock[] = [];
  let allDayCount = 0;
  for (const ev of calendar.list) {
    if (ev.allDay) {
      allDayCount += 1;
      continue;
    }
    const sh = isoToHour(ev.start);
    const eh = isoToHour(ev.end);
    if (sh == null || eh == null) continue;
    if (eh <= startH || sh >= endH) continue;
    youBlocks.push({
      laneKey: 'you',
      label: ev.summary || '(untitled event)',
      hue: '#0EA5E9',
      startH: Math.max(startH, sh),
      endH: Math.min(endH, eh),
      source: 'event',
    });
  }

  // Per-rascal task blocks. Tasks have due_at but not start/end — render
  // each as a 30-min marker at its due hour. Today only.
  const taskByAgent: Record<string, TimelineBlock[]> = {};
  for (const t of tasks.list) {
    if (!t.assigned_agent) continue;
    if (t.status === 'done') continue;
    if (!isToday(t.due_at)) continue;
    const sh = isoToHour(t.due_at!);
    if (sh == null) continue;
    if (sh < startH - 0.25 || sh > endH + 0.25) continue;
    const lane = taskByAgent[t.assigned_agent] ?? [];
    lane.push({
      laneKey: t.assigned_agent,
      label: t.title,
      hue: agentHueFromDashboard(t.assigned_agent),
      startH: Math.max(startH, sh - 0.25),
      endH: Math.min(endH, sh + 0.25),
      source: 'task',
    });
    taskByAgent[t.assigned_agent] = lane;
  }

  // Compose lane list: You (always), then each rascal that has tasks today.
  // Sort agents with tasks alphabetically for stable order.
  const agentLaneKeys = Object.keys(taskByAgent).sort();
  type Lane = { title: string; agent?: string; blocks: TimelineBlock[]; allDay?: number };
  const lanes: Lane[] = [
    { title: 'You', blocks: youBlocks, allDay: allDayCount },
    ...agentLaneKeys.map((handle) => {
      const r = rascals.list.find((x) => x.handle === handle);
      return {
        title: r?.displayName ?? handle,
        agent: handle,
        blocks: taskByAgent[handle],
      };
    }),
  ];

  const loading = !calendar.loaded || !tasks.loaded;
  const empty =
    calendar.loaded && tasks.loaded && lanes.length === 1 && lanes[0].blocks.length === 0 && !allDayCount;

  return (
    <Panel
      title="Today · Timeline (from Calendar)"
      icon={<Clock size={14} />}
      accent="linear-gradient(135deg, #7C3CFF 0%, #0EA5E9 100%)"
      className="flex-1"
      meta={
        <span className="vs-mono text-[10px]" style={{ color: '#9AA8C2' }} data-testid="timeline-meta">
          {loading
            ? 'LOADING…'
            : `${youBlocks.length} EVENTS · ${Object.values(taskByAgent).reduce((s, b) => s + b.length, 0)} TASKS`}
        </span>
      }
    >
      <div className="px-3.5 pt-2.5 pb-4 relative" data-testid="timeline-panel">
        {empty && (
          <div className="text-[12px] italic py-3" style={{ color: '#74849A' }}>
            No events or tasks scheduled in the {startH}–{endH}:00 window today.
          </div>
        )}
        {!empty && (
          <>
            <div className="flex relative h-4 ml-[110px]" style={{ color: '#74849A' }}>
              {hours.map((h) => (
                <div key={h} className="vs-mono flex-1 text-[10px]">
                  {h}:00
                </div>
              ))}
            </div>
            {lanes.map((lane) => {
              const { packed, rowCount } = packBlocksIntoRows(lane.blocks);
              const rowHeight = 22; // px per row of blocks
              const rowGap = 3;
              const trackHeight = rowCount * rowHeight + Math.max(0, rowCount - 1) * rowGap;
              return (
              <div
                key={lane.agent ?? 'you'}
                className="flex items-center gap-2.5 relative py-1.5"
                data-timeline-lane={lane.agent ?? 'you'}
                data-row-count={rowCount}
              >
                <div className="w-[100px] flex items-center gap-2 min-w-0 self-start pt-1">
                  {lane.agent ? (
                    <AgentAvatar handle={lane.agent} displayName={lane.title} size={18} />
                  ) : (
                    <div
                      className="w-[18px] h-[18px] rounded-full"
                      style={{ background: 'linear-gradient(135deg, #7C3CFF 0%, #0EA5E9 100%)' }}
                    />
                  )}
                  <span className="text-[11px] truncate" style={{ color: '#F1F4FF' }}>
                    {lane.title}
                    {lane.allDay ? (
                      <span className="vs-mono ml-1 text-[9px]" style={{ color: '#74849A' }}>
                        +{lane.allDay}d
                      </span>
                    ) : null}
                  </span>
                </div>
                <div
                  className="flex-1 relative"
                  style={{
                    borderLeft: '1px solid rgba(216,228,240,0.95)',
                    height: trackHeight,
                  }}
                >
                  {hours.map((_, i) => (
                    <div
                      key={i}
                      className="absolute top-0 bottom-0"
                      style={{
                        left: `${(i / hours.length) * 100}%`,
                        borderLeft: '1px dashed rgba(14,165,233,0.12)',
                      }}
                    />
                  ))}
                  {packed.map((b, bi) => (
                    <div
                      key={`${lane.agent ?? 'you'}-${bi}`}
                      title={b.label}
                      className="absolute flex items-center gap-1.5 rounded-md text-[10.5px] px-2 truncate"
                      style={{
                        top: b.row * (rowHeight + rowGap),
                        height: rowHeight,
                        left: `${pct(b.startH)}%`,
                        width: `calc(${Math.max(2, pct(b.endH) - pct(b.startH))}% - 2px)`,
                        background: `linear-gradient(135deg, ${b.hue}44, ${b.hue}22)`,
                        border: `1px solid ${b.hue}88`,
                        color: '#F1F4FF',
                        boxShadow: `inset 0 0 12px ${b.hue}22`,
                      }}
                    >
                      <span
                        className="w-1 h-1 rounded-full flex-shrink-0"
                        style={{ background: b.hue, boxShadow: `0 0 6px ${b.hue}` }}
                      />
                      <span className="truncate">{b.label}</span>
                    </div>
                  ))}
                </div>
              </div>
              );
            })}
          </>
        )}
      </div>
    </Panel>
  );
}

/** Pull rascal hue without re-importing — uses the public helper from AgentAvatar. */
function agentHueFromDashboard(handle: string): string {
  // Keep this small to avoid a full import cycle; the hue-cycle here mirrors
  // the THEMES table in components/AgentAvatar.tsx for the 10 known rascals.
  // Falls back to a neutral grey for unknowns.
  const map: Record<string, string> = {
    alfalfa: '#7C3CFF', buckwheat: '#FF8A3D', butch: '#ff5c5c',
    darla: '#FF4D8D', froggy: '#20B26B', petey: '#a07060',
    porky: '#ff8c5c', spanky: '#0EA5E9', stymie: '#d6b6ff',
    wheezer: '#9d8bff',
  };
  return map[handle] ?? '#9AA8C2';
}

// ──────────────────────────────────────────────────────────────────────
// Page
// ──────────────────────────────────────────────────────────────────────

function getDisplayName(): string {
  try {
    const raw = localStorage.getItem('boss_user');
    if (!raw) return 'there';
    const first = (JSON.parse(raw).displayName ?? 'there').split(/\s+/)[0];
    return first || 'there';
  } catch {
    return 'there';
  }
}

function greetingFor(d: Date): string {
  const h = d.getHours();
  if (h < 5) return 'Burning the candle';
  if (h < 12) return 'Morning';
  if (h < 17) return 'Afternoon';
  if (h < 21) return 'Evening';
  return 'Late';
}

// ──────────────────────────────────────────────────────────────────────
// Customizable widget layout — Kane: "let them choose which widgets/tiles
// show… a pop-up gallery to pick and choose." Selection persists per browser.
// ──────────────────────────────────────────────────────────────────────

type WidgetId = 'agents' | 'tasks' | 'activity' | 'inbox' | 'slack' | 'whatsapp' | 'timeline';

const WIDGET_CATALOG: { id: WidgetId; label: string; blurb: string; wide?: boolean }[] = [
  { id: 'agents',   label: 'Employee Agents',  blurb: 'Your AI staff and who is online' },
  { id: 'tasks',    label: 'Task Board',       blurb: 'Today / overdue / tomorrow at a glance' },
  { id: 'activity', label: 'Live Activity',    blurb: 'Recent work your agents completed' },
  { id: 'inbox',    label: 'Inbox',            blurb: 'Unread email that needs you' },
  { id: 'slack',    label: 'Slack',            blurb: 'Threads that need a reply' },
  { id: 'whatsapp', label: 'WhatsApp',         blurb: 'Unread WhatsApp conversations' },
  { id: 'timeline', label: "Today's Timeline", blurb: 'Your calendar, stacked by hour', wide: true },
];

const DEFAULT_WIDGETS: WidgetId[] = ['agents', 'tasks', 'activity', 'inbox', 'timeline'];
const WIDGETS_KEY = 'boss_dash_widgets';

function useDashWidgets(): { enabled: Set<WidgetId>; toggle: (id: WidgetId) => void } {
  const [enabled, setEnabled] = useState<Set<WidgetId>>(() => {
    try {
      const raw = localStorage.getItem(WIDGETS_KEY);
      if (raw) return new Set(JSON.parse(raw) as WidgetId[]);
    } catch { /* ignore */ }
    return new Set(DEFAULT_WIDGETS);
  });
  const toggle = (id: WidgetId) =>
    setEnabled((prev) => {
      const next = new Set(prev);
      if (next.has(id)) next.delete(id); else next.add(id);
      try { localStorage.setItem(WIDGETS_KEY, JSON.stringify([...next])); } catch { /* ignore */ }
      return next;
    });
  return { enabled, toggle };
}

function WidgetGallery({ enabled, toggle, onClose }: {
  enabled: Set<WidgetId>;
  toggle: (id: WidgetId) => void;
  onClose: () => void;
}) {
  useEffect(() => {
    const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') onClose(); };
    document.addEventListener('keydown', onKey);
    return () => document.removeEventListener('keydown', onKey);
  }, [onClose]);
  return (
    <div className="fixed inset-0 z-[80] flex items-center justify-center p-6" role="dialog" aria-modal="true">
      <div className="absolute inset-0 bg-black/70 backdrop-blur-sm" onClick={onClose} />
      <div
        className="relative w-full max-w-lg rounded-xl p-5 shadow-xl"
        style={{ background: `linear-gradient(180deg, ${DASH.panel}, ${DASH.panel2})`, border: `1px solid ${DASH.border}`, color: DASH.text }}
      >
        <header className="flex items-start justify-between mb-4">
          <div>
            <div className="vs-mono text-[10px] uppercase tracking-[0.22em]" style={{ color: DASH.textMuted }}>Customize</div>
            <h2 className="text-lg font-semibold mt-1 flex items-center gap-2">
              <LayoutGrid className="w-4 h-4" style={{ color: DASH.violet }} /> Choose your widgets
            </h2>
            <p className="text-[12px] mt-1" style={{ color: DASH.textMuted }}>Pick which tiles show on your dashboard. Saved on this browser.</p>
          </div>
          <button type="button" onClick={onClose} aria-label="Close" style={{ color: DASH.textMuted }}><X className="w-4 h-4" /></button>
        </header>
        <div className="space-y-2">
          {WIDGET_CATALOG.map((w) => {
            const on = enabled.has(w.id);
            return (
              <button
                key={w.id}
                type="button"
                onClick={() => toggle(w.id)}
                className="w-full flex items-center gap-3 px-3 py-2.5 rounded-lg text-left"
                style={{ background: on ? DASH.panel3 : DASH.panel2, border: `1px solid ${on ? DASH.violet : DASH.border}` }}
              >
                <div
                  className="h-5 w-5 rounded flex items-center justify-center shrink-0"
                  style={{ background: on ? DASH.violet : 'transparent', border: `1px solid ${on ? DASH.violet : DASH.textMuted}` }}
                >
                  {on && <Check className="w-3.5 h-3.5" style={{ color: '#fff' }} />}
                </div>
                <div className="min-w-0">
                  <div className="text-[13.5px] font-medium">{w.label}</div>
                  <div className="text-[11.5px] truncate" style={{ color: DASH.textMuted }}>{w.blurb}</div>
                </div>
              </button>
            );
          })}
        </div>
      </div>
    </div>
  );
}

// Trust/health gauge (top-right of the title bar). Demo value on Vasari;
// Kane's wires to real data (Keap/Katalyst) via Spanky.
function TrustGauge({ value = 92 }: { value?: number }) {
  const r = 26;
  const c = 2 * Math.PI * r;
  const dash = (value / 100) * c;
  return (
    <div
      className="relative shrink-0 grid place-items-center"
      style={{ width: 64, height: 64 }}
      data-testid="trust-gauge"
      title="Demo metric — to be wired to real data"
    >
      <svg width="64" height="64" viewBox="0 0 64 64" style={{ transform: 'rotate(-90deg)' }}>
        <circle cx="32" cy="32" r={r} fill="none" stroke="#232A4D" strokeWidth="6" />
        <circle
          cx="32" cy="32" r={r} fill="none" stroke="url(#tg-grad)" strokeWidth="6"
          strokeLinecap="round" strokeDasharray={`${dash} ${c}`}
        />
        <defs>
          <linearGradient id="tg-grad" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stopColor="#7C3CFF" />
            <stop offset="100%" stopColor="#0EA5E9" />
          </linearGradient>
        </defs>
      </svg>
      <div className="absolute text-[14px] font-semibold" style={{ color: '#F1F4FF' }}>{value}%</div>
    </div>
  );
}

// Bottom KPI / revenue strip. Demo values on Vasari (placeholder until a
// real source is wired); Kane's pulls from Keap + Katalyst via Spanky.
const KPI_STRIP: { label: string; value: string; sub: string }[] = [
  { label: 'TOTAL REVENUE', value: '$1.24M', sub: 'YTD · demo' },
  { label: 'THIS MONTH', value: '$120,450', sub: '+34.6% · demo' },
  { label: 'AVG RESPONSE', value: '1.2s', sub: 'agent latency · demo' },
  { label: 'CSAT', value: '4.9/5', sub: 'satisfaction · demo' },
];
function KpiStrip() {
  return (
    <div className="grid grid-cols-2 lg:grid-cols-4 gap-3.5 mt-3.5" data-testid="kpi-strip">
      {KPI_STRIP.map((k) => (
        <div key={k.label} className="rounded-[14px] p-3.5" style={{ background: DASH.panel2, border: `1px solid ${DASH.border}` }}>
          <div className="vs-mono text-[9px] tracking-[0.2em] uppercase" style={{ color: '#74849A' }}>{k.label}</div>
          <div className="text-[22px] font-semibold mt-1" style={{ color: '#F1F4FF' }}>{k.value}</div>
          <div className="text-[10.5px] mt-0.5" style={{ color: '#9AA8C2' }}>{k.sub}</div>
        </div>
      ))}
    </div>
  );
}

export default function Dashboard() {
  const [now, setNow] = useState(() => new Date());
  useEffect(() => {
    const i = setInterval(() => setNow(new Date()), 1000);
    return () => clearInterval(i);
  }, []);

  const rascalsState = useRascals();
  const tasksState = useTasks();
  const recentActivityState = useRecentActivity();
  const automationsState = useAutomations();
  const inboxState = useInbox();
  const slackAttentionState = useSlackAttention();
  const calendarState = useCalendarToday();
  const whatsappState = useWhatsApp();
  const auth = useAuthHealth();
  const { enabled: enabledWidgets, toggle: toggleWidget } = useDashWidgets();
  const [galleryOpen, setGalleryOpen] = useState(false);
  const automationsTotal =
    (automationsState.data?.n8n.status?.total ?? 0) +
    (automationsState.data?.make.status?.total ?? 0);
  const automationsActive =
    (automationsState.data?.n8n.status?.active ?? 0) +
    (automationsState.data?.make.status?.active ?? 0);
  const enabledRascals = rascalsState.list.filter((r) => r.enabled).length;

  // KPIs derived from the live tasks list.
  const tasksToday = useMemo(() => {
    if (!tasksState.loaded) return null;
    const today = new Date();
    return tasksState.list.filter((t) => {
      if (t.status === 'done') return false;
      if (!t.due_at) return false;
      const d = new Date(t.due_at);
      return (
        d.getFullYear() === today.getFullYear() &&
        d.getMonth() === today.getMonth() &&
        d.getDate() === today.getDate()
      );
    }).length;
  }, [tasksState]);

  const blockedCount = useMemo(
    () => tasksState.list.filter((t) => t.status === 'blocked').length,
    [tasksState],
  );

  // Calendar stat for the top strip (Kane: non-builders want their calendar, not automations).
  const calendarStat = useMemo(() => {
    if (!calendarState.loaded) return { value: '—', sub: 'loading calendar…' };
    const total = calendarState.list.length;
    const nowMs = Date.now();
    const next = [...calendarState.list]
      .filter((e) => e.start && new Date(e.start).getTime() >= nowMs)
      .sort((a, b) => new Date(a.start).getTime() - new Date(b.start).getTime())[0];
    const sub = total === 0
      ? 'no events today'
      : next
        ? `next: ${(next.summary || 'event').slice(0, 22)} ${new Date(next.start).toLocaleTimeString('en-US', { hour: 'numeric', minute: '2-digit' })}`
        : `${total} today · all done`;
    return { value: String(total), sub };
  }, [calendarState]);

  // Which tile each widget id renders. Filtered by the user's gallery choices.
  const widgetNode: Record<WidgetId, React.ReactNode> = {
    agents:   <AgentRoster />,
    tasks:    <KanbanPeek state={tasksState} />,
    activity: <LiveActivity state={recentActivityState} />,
    inbox:    <InboxPanel state={inboxState} />,
    slack:    <SlackAttentionPanel state={slackAttentionState} />,
    whatsapp: <WhatsAppPanel state={whatsappState} />,
    timeline: <TimelinePanel calendar={calendarState} tasks={tasksState} rascals={rascalsState} />,
  };
  const activeWidgets = WIDGET_CATALOG.filter((w) => enabledWidgets.has(w.id));
  const gridWidgets = activeWidgets.filter((w) => !w.wide);
  const wideWidgets = activeWidgets.filter((w) => w.wide);

  const displayName = useMemo(getDisplayName, []);
  const dateLabel = useMemo(
    () =>
      now
        .toLocaleDateString('en-US', { weekday: 'long', month: 'short', day: 'numeric' })
        .toUpperCase(),
    [now],
  );
  const timeLabel = useMemo(() => now.toLocaleTimeString('en-US', { hour12: false }), [now]);
  const greeting = useMemo(() => greetingFor(now), [now]);

  return (
    <div
      data-testid="dashboard-v2"
      className="relative h-full overflow-auto p-4"
      style={{ background: 'var(--v-base)' }}
    >
      {auth.expired && (
        <div
          data-testid="auth-expired-banner"
          role="alert"
          className="mb-3 rounded-lg px-4 py-2.5 flex items-center gap-3"
          style={{
            background: 'linear-gradient(90deg, rgba(255,184,107,0.18), rgba(255,92,200,0.12))',
            border: '1px solid rgba(255,184,107,0.45)',
            color: '#ffd9b0',
          }}
        >
          <span
            aria-hidden
            className="w-2 h-2 rounded-full flex-shrink-0"
            style={{ background: '#FF8A3D', boxShadow: '0 0 8px #FF8A3D' }}
          />
          <span className="text-[12.5px] flex-1">
            Your session has expired — every panel below is showing empty data because the API is rejecting requests as unauthenticated. Sign out and sign back in to refresh.
          </span>
          <button
            type="button"
            onClick={() => {
              try { localStorage.removeItem('boss_token'); } catch { /* ignore */ }
              window.location.assign('/login');
            }}
            className="text-[11.5px] font-semibold px-3 py-1 rounded-md"
            style={{
              background: 'rgba(255,184,107,0.25)',
              border: '1px solid rgba(255,184,107,0.6)',
              color: '#ffe0c0',
            }}
          >
            Sign in again
          </button>
        </div>
      )}

      {/* Everything below is scaled up ~18% for legibility (Kane: bigger fonts). */}
      <div style={{ zoom: 1.18 }}>
      {/* Title bar */}
      <div className="flex items-end gap-4 mb-4">
        <div className="flex-1">
          <div
            className="vs-mono text-[10px] tracking-[0.26em]"
            style={{ color: '#74849A' }}
          >
            COMMAND CENTER / {dateLabel}
          </div>
          <div className="flex items-baseline gap-3.5 mt-1.5">
            <h1
              className="m-0 text-[28px] font-semibold"
              style={{ letterSpacing: '-0.01em' }}
            >
              {greeting},{' '}
              <span
                style={{
                  background: 'linear-gradient(135deg, #7C3CFF 0%, #0EA5E9 100%)',
                  WebkitBackgroundClip: 'text',
                  backgroundClip: 'text',
                  color: 'transparent',
                }}
              >
                {displayName}
              </span>
              .
            </h1>
            <div className="vs-mono text-[11px]" style={{ color: '#9AA8C2' }}>
              {timeLabel}
            </div>
          </div>
          <div className="text-[13px] mt-1" style={{ color: '#9AA8C2' }} data-testid="dashboard-substat">
            {tasksState.loaded ? `${blockedCount} threads need you` : 'tasks…'}
            {' · '}
            {rascalsState.loaded ? `${enabledRascals} agents online` : 'agents…'}
            {' · '}
            {automationsState.loaded
              ? `${automationsActive}/${automationsTotal} automations warm`
              : 'automations…'}
          </div>
        </div>
        <TrustGauge />
        <button
          type="button"
          onClick={() => setGalleryOpen(true)}
          className="flex items-center gap-1.5 text-[12px] font-semibold px-3 py-1.5 rounded-md shrink-0"
          style={{ background: DASH.panel2, border: `1px solid ${DASH.border}`, color: DASH.text }}
          data-testid="dashboard-customize"
        >
          <LayoutGrid className="w-3.5 h-3.5" /> Customize
        </button>
      </div>

      {/* Stat strip */}
      <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-3.5">
        <StatCard
          label="EMPLOYEE AGENTS"
          value="—"
          sub="coming soon · purpose-built staff"
          hue="purple"
          spark="rise"
        />
        <StatCard
          label="TASKS TODAY"
          value={tasksToday == null ? '—' : String(tasksToday)}
          sub={
            tasksState.loaded
              ? `${tasksState.list.filter((t) => t.status === 'active').length} active · ${blockedCount} blocked`
              : 'loading tasks…'
          }
          hue="pink"
          spark="split"
        />
        <StatCard
          label="INBOX"
          value={inboxState.loaded ? String(inboxState.list.length) : '—'}
          sub={
            inboxState.loaded
              ? inboxState.email
                ? `${inboxState.list.length} unread · ${inboxState.email}`
                : inboxState.list.length === 0
                  ? 'no unread mail'
                  : `${inboxState.list.length} unread`
              : 'loading inbox…'
          }
          hue="green"
          spark="rise"
        />
        <StatCard
          label="CALENDAR"
          value={calendarStat.value}
          sub={calendarStat.sub}
          hue="blue"
          spark="wave"
        />
      </div>

      {/* Widget grid — symmetric, equal-height, scroll-inside tiles. Kane:
          same-size boxes, no big empty black gaps, scroll feature. Wide
          widgets (timeline) span the full row. */}
      <div className="grid gap-3.5 mt-3.5 grid-cols-1 lg:grid-cols-2">
        {gridWidgets.map((w) => (
          <div key={w.id} className="h-[340px] min-h-0">{widgetNode[w.id]}</div>
        ))}
        {wideWidgets.map((w) => (
          <div key={w.id} className="h-[300px] min-h-0 lg:col-span-2">{widgetNode[w.id]}</div>
        ))}
        {activeWidgets.length === 0 && (
          <div
            className="lg:col-span-2 rounded-[14px] p-8 text-center text-[13px]"
            style={{ border: `1px dashed ${DASH.border}`, color: DASH.textMuted }}
          >
            No widgets selected. Click “Customize” to choose which tiles show.
          </div>
        )}
      </div>
      <KpiStrip />
      </div>

      {galleryOpen && (
        <WidgetGallery enabled={enabledWidgets} toggle={toggleWidget} onClose={() => setGalleryOpen(false)} />
      )}
    </div>
  );
}

export { Dashboard };
