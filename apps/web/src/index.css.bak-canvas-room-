@import './styles/tokens-ir-whitelabel.css';

@tailwind base;
@tailwind components;
@tailwind utilities;

@layer base {
  * {
    box-sizing: border-box;
  }

  html {
    color-scheme: dark;
    /* Kane 06-13: larger, easier on 40-60yo eyes. ~+25% root size. */
    font-size: 118.75%;
  }

  body {
    background: var(--v-base-bg, var(--v-base));
    background-color: var(--v-base);
    color: var(--v-text);
    font-family: 'Space Grotesk', system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
    -webkit-font-smoothing: antialiased;
    letter-spacing: 0;
    min-height: 100vh;
  }

  ::-webkit-scrollbar {
    width: 6px;
    height: 6px;
  }

  ::-webkit-scrollbar-track {
    background: rgba(8, 13, 28, 0.38);
  }

  ::-webkit-scrollbar-thumb {
    background: rgba(148, 177, 214, 0.32);
    border-radius: 999px;
  }

  ::-webkit-scrollbar-thumb:hover {
    background: rgba(45, 212, 255, 0.52);
  }
}

@layer components {
  .aios-main {
    position: relative;
    background: linear-gradient(180deg, rgba(3, 7, 17, 0.06) 0%, rgba(3, 7, 17, 0.36) 100%);
  }

  .login-entrance-page .aios-atmosphere-grid {
    opacity: 0.18;
    mix-blend-mode: screen;
  }

  .login-access-panel {
    border: 1px solid rgba(226, 232, 240, 0.8);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.8), rgba(241, 245, 249, 0.52)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.11), rgba(245, 158, 11, 0.07));
    color: #0f172a;
    box-shadow: 0 28px 82px rgba(15, 23, 42, 0.18), inset 0 1px 0 rgba(255, 255, 255, 0.82);
    backdrop-filter: blur(18px) saturate(1.1);
  }

  .login-access-panel .btn-primary {
    background: linear-gradient(135deg, #0ea5e9, #14b8a6);
    color: white;
    border-color: rgba(14, 165, 233, 0.58);
    box-shadow: 0 14px 28px rgba(14, 165, 233, 0.22);
  }

  .aios-room-wash {
    background:
      linear-gradient(90deg, rgba(3, 7, 17, 0.56), rgba(3, 7, 17, 0.12) 46%, rgba(3, 7, 17, 0.42)),
      linear-gradient(180deg, rgba(3, 7, 17, 0.2), rgba(3, 7, 17, 0.32));
  }

  .aios-room-wash-lobby {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.02) 44%, rgba(23, 37, 84, 0.14)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.14), rgba(245, 158, 11, 0.08));
  }

  .aios-room-wash-wellness {
    background:
      linear-gradient(90deg, rgba(15, 23, 42, 0.05), rgba(255, 255, 255, 0.005) 48%, rgba(15, 23, 42, 0.07)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.025), rgba(20, 184, 166, 0.018));
  }

  .aios-room-wash-planning {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.18), rgba(255, 255, 255, 0.04) 50%, rgba(15, 23, 42, 0.14)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.12), rgba(14, 165, 233, 0.08));
  }

  .aios-room-wash-mailroom,
  .aios-room-wash-revenue,
  .aios-room-wash-schedule,
  .aios-room-wash-broadcast,
  .aios-room-wash-archive,
  .aios-room-wash-control,
  .aios-room-wash-aiops {
    background:
      linear-gradient(90deg, rgba(255, 255, 255, 0.14), rgba(255, 255, 255, 0.02) 48%, rgba(15, 23, 42, 0.2)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(15, 23, 42, 0.16));
  }

  .aios-room-glass {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.02), rgba(3, 7, 17, 0.18)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.04), transparent 38%, rgba(255, 209, 102, 0.04));
  }

  .aios-room-lines {
    opacity: 0.16;
  }

  .aios-atmosphere-grid {
    opacity: 0.32;
    background-image:
      linear-gradient(rgba(45, 212, 255, 0.14) 1px, transparent 1px),
      linear-gradient(90deg, rgba(45, 212, 255, 0.12) 1px, transparent 1px),
      linear-gradient(120deg, transparent 0%, rgba(255, 209, 102, 0.07) 38%, transparent 68%);
    background-size: 72px 72px, 72px 72px, 100% 100%;
    mask-image: linear-gradient(180deg, transparent 0%, black 24%, black 74%, transparent 100%);
  }

  .aios-command-horizon {
    opacity: 0.72;
    background:
      linear-gradient(180deg, transparent 0%, rgba(45, 212, 255, 0.08) 48%, rgba(3, 7, 17, 0.88) 100%),
      repeating-linear-gradient(90deg, rgba(45, 212, 255, 0.16) 0 1px, transparent 1px 110px);
    clip-path: polygon(0 34%, 14% 24%, 31% 36%, 49% 18%, 66% 31%, 82% 20%, 100% 34%, 100% 100%, 0 100%);
  }

  .aios-page {
    min-height: 100%;
    color: var(--v-text);
    background: transparent;
  }

  .aios-page-pad {
    padding: clamp(14px, 2vw, 24px);
  }

  .aios-command-hero {
    border: 1px solid rgba(148, 177, 214, 0.2);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(8, 13, 28, 0.68), rgba(11, 19, 38, 0.5) 48%, rgba(24, 31, 58, 0.42)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.16), rgba(255, 209, 102, 0.08));
    box-shadow: 0 20px 70px rgba(0, 0, 0, 0.24), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    backdrop-filter: blur(16px) saturate(1.08);
  }

  .aios-command-hero h1,
  .aios-command-hero h2 {
    letter-spacing: 0;
  }

  .aios-whiteboard {
    position: relative;
    border: 1px solid rgba(232, 244, 255, 0.28);
    border-radius: 8px;
    background:
      linear-gradient(135deg, rgba(9, 15, 28, 0.42), rgba(15, 26, 44, 0.28) 48%, rgba(255, 255, 255, 0.08)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.12), rgba(255, 209, 102, 0.08));
    box-shadow: 0 28px 80px rgba(0, 0, 0, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.18);
    backdrop-filter: blur(10px) saturate(1.05);
  }

  .aios-whiteboard::before {
    content: '';
    position: absolute;
    inset: 8px;
    border-radius: 6px;
    pointer-events: none;
    border: 1px solid rgba(232, 244, 255, 0.1);
    background-image:
      linear-gradient(rgba(232, 244, 255, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(232, 244, 255, 0.045) 1px, transparent 1px);
    background-size: 34px 34px;
    opacity: 0.58;
  }

  .aios-whiteboard > * {
    position: relative;
    z-index: 1;
  }

  .aios-whiteboard .aios-command-hero {
    background:
      linear-gradient(135deg, rgba(5, 10, 23, 0.72), rgba(16, 29, 55, 0.52)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.2), rgba(255, 209, 102, 0.1));
  }

  .aios-whiteboard .dashboard-whiteboard-grid {
    position: relative;
  }

  .aios-whiteboard .dashboard-whiteboard-grid::before {
    content: '';
    position: absolute;
    inset: -8px;
    border-radius: 8px;
    pointer-events: none;
    background:
      linear-gradient(90deg, rgba(12, 32, 54, 0.06), transparent 22%, transparent 78%, rgba(12, 32, 54, 0.06)),
      linear-gradient(180deg, rgba(255, 255, 255, 0.25), transparent 16%);
  }

  .aios-lobby-board {
    width: min(100%, 1500px);
    margin-inline: auto;
    background:
      linear-gradient(135deg, rgba(8, 13, 28, 0.44), rgba(18, 31, 49, 0.26) 48%, rgba(255, 255, 255, 0.12)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.1), rgba(255, 209, 102, 0.08));
  }

  .aios-room-lobby .aios-main {
    background:
      radial-gradient(circle at 50% 28%, rgba(255, 255, 255, 0.34), transparent 30%),
      linear-gradient(180deg, rgba(255, 255, 255, 0.08), rgba(15, 23, 42, 0.08));
  }

  .dashboard-room-native {
    position: relative;
    border: 1px solid rgba(236, 247, 255, 0.52);
    border-radius: 8px;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.48), transparent 28%),
      radial-gradient(circle at 82% 16%, rgba(125, 211, 252, 0.2), transparent 26%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.52), rgba(241, 245, 249, 0.28));
    box-shadow: 0 28px 80px rgba(15, 23, 42, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.68);
    backdrop-filter: blur(8px) saturate(1.08);
  }

  .dashboard-executive-lobby {
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.28), transparent 26%),
      radial-gradient(circle at 82% 16%, rgba(125, 211, 252, 0.14), transparent 24%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.38), rgba(241, 245, 249, 0.18));
    border-color: rgba(236, 247, 255, 0.44);
    box-shadow: 0 24px 70px rgba(15, 23, 42, 0.14), inset 0 1px 0 rgba(255, 255, 255, 0.54);
    backdrop-filter: blur(6px) saturate(1.06);
  }

  .dashboard-room-native::before {
    content: '';
    position: absolute;
    inset: 10px;
    pointer-events: none;
    border: 1px solid rgba(236, 247, 255, 0.28);
    border-radius: 6px;
    background-image:
      linear-gradient(rgba(14, 165, 233, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.04) 1px, transparent 1px);
    background-size: 38px 38px;
    mask-image: radial-gradient(circle at 50% 38%, black, transparent 76%);
  }

  .dashboard-executive-lobby::before {
    opacity: 0.52;
    mask-image: radial-gradient(circle at 50% 34%, black, transparent 70%);
  }

  .dashboard-room-native > * {
    position: relative;
    z-index: 1;
  }

  .dashboard-room-native .aios-command-hero {
    border-color: rgba(226, 232, 240, 0.64);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.7), rgba(241, 245, 249, 0.38)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.12), rgba(245, 158, 11, 0.08));
    box-shadow: 0 18px 48px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }

  .dashboard-executive-lobby .aios-command-hero {
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.76), rgba(241, 245, 249, 0.48)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.12), rgba(245, 158, 11, 0.08));
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.78);
  }

  .dashboard-room-native .aios-command-hero h1 {
    color: #0f172a;
    text-shadow: 0 1px 0 rgba(255, 255, 255, 0.62);
  }

  .dashboard-room-native .aios-command-hero .vs-mono,
  .dashboard-room-native .aios-command-hero [data-testid='dashboard-substat'] {
    color: #51627a !important;
  }

  .dashboard-room-native .dashboard-whiteboard-grid {
    position: relative;
  }

  .dashboard-executive-lobby .dashboard-whiteboard-grid {
    position: relative;
  }

  .dashboard-executive-lobby .dashboard-whiteboard-grid:last-of-type {
    grid-auto-rows: 300px !important;
  }

  .dashboard-executive-lobby .group > .relative,
  .dashboard-executive-lobby .dashboard-whiteboard-grid > .relative,
  .dashboard-executive-lobby [data-testid^="dashboard"] {
    box-shadow: 0 16px 38px rgba(15, 23, 42, 0.1);
  }

  .dashboard-room-native .group > .relative,
  .dashboard-room-native .dashboard-whiteboard-grid > .relative,
  .dashboard-room-native [data-testid^="dashboard"] {
    backdrop-filter: blur(12px) saturate(1.08);
  }

  .dashboard-floating-lobby {
    position: relative;
    width: min(100%, 1760px);
    margin-inline: auto;
    height: clamp(560px, calc(100dvh - 150px), 920px);
    max-height: calc(100dvh - 150px);
    min-height: 0;
  }

  .dashboard-floating-stage {
    position: relative;
    height: 100%;
    min-height: 100%;
    isolation: isolate;
  }

  .dashboard-floating-tile {
    position: absolute;
    min-width: 0;
    min-height: 0;
    border-radius: 8px;
  }

  .dashboard-floating-content {
    border-radius: 8px;
    overflow: hidden;
    box-shadow:
      0 18px 44px rgba(15, 23, 42, 0.14),
      inset 0 1px 0 rgba(255, 255, 255, 0.48);
    backdrop-filter: blur(9px) saturate(1.06);
  }

  .dashboard-floating-content > * {
    height: 100%;
    min-height: 0;
  }

  .dashboard-floating-tile[data-floating-tile='hero'] .dashboard-floating-content,
  .dashboard-floating-tile[data-floating-tile='life'] .dashboard-floating-content {
    box-shadow: none;
    backdrop-filter: none;
    background: transparent;
  }

  .dashboard-floating-tile[data-floating-tile='brief'] .dashboard-floating-content,
  .dashboard-floating-tile[data-floating-tile='tasks'] .dashboard-floating-content,
  .dashboard-floating-tile[data-floating-tile='timeline'] .dashboard-floating-content {
    box-shadow:
      0 14px 36px rgba(15, 23, 42, 0.08),
      inset 0 1px 0 rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(9px) saturate(1.04);
  }

  .dashboard-floating-tile[data-floating-tile='brief'] .dashboard-floating-content > *,
  .dashboard-floating-tile[data-floating-tile='tasks'] .dashboard-floating-content > *,
  .dashboard-floating-tile[data-floating-tile='timeline'] .dashboard-floating-content > * {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.1), rgba(241, 248, 255, 0.1)) !important;
    border-color: rgba(100, 116, 139, 0.16) !important;
    box-shadow: 0 10px 28px rgba(24, 34, 53, 0.05) !important;
  }

  .dashboard-floating-lobby .aios-command-hero {
    border: 1px solid transparent;
    border-radius: 8px;
    background: transparent;
    color: #073563;
    box-shadow: none;
    backdrop-filter: none;
  }

  .dashboard-floating-lobby .aios-command-hero h1 {
    color: #072f5a;
    text-shadow:
      0 0 16px rgba(255, 255, 255, 0.9),
      0 2px 7px rgba(9, 48, 92, 0.34);
  }

  .dashboard-floating-lobby .dashboard-floating-hero .vs-mono,
  .dashboard-floating-lobby .dashboard-floating-hero [data-testid='dashboard-substat'] {
    text-shadow:
      0 0 12px rgba(255, 255, 255, 0.88),
      0 1px 4px rgba(9, 48, 92, 0.26);
  }

  .dashboard-life-card .vs-mono {
    color: #173d6b !important;
  }

  .dashboard-life-card {
    display: flex;
    flex-direction: column;
    padding: 10px !important;
  }

  .dashboard-life-card > .flex {
    margin-bottom: 6px;
  }

  .dashboard-life-grid {
    display: grid;
    flex: 1;
    min-height: 0;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(7, minmax(0, 1fr));
    grid-auto-rows: minmax(0, 1fr);
    gap: 5px;
  }

  .dashboard-life-signal {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 1px;
    min-width: 0;
    min-height: 0;
    border: 1px solid rgba(148, 163, 184, 0.34);
    border-radius: 8px;
    padding: 4px 8px;
    text-align: left;
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.74), rgba(235, 247, 255, 0.48)),
      linear-gradient(90deg, color-mix(in srgb, var(--life-signal-color) 12%, transparent), transparent);
    color: #0d2f59;
    box-shadow: 0 8px 22px rgba(15, 23, 42, 0.08), inset 0 1px 0 rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(8px) saturate(1.06);
    overflow: hidden;
  }

  .dashboard-life-signal > .flex {
    min-width: 0;
  }

  .dashboard-life-signal:hover,
  .dashboard-life-signal:focus-visible {
    border-color: var(--life-signal-color);
    outline: none;
  }

  .dashboard-life-chip {
    display: inline-flex;
    width: 20px;
    height: 14px;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    background: color-mix(in srgb, var(--life-signal-color) 18%, white);
    color: #0d2f59;
    font: 700 7.5px/1 var(--vs-mono, ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace);
    flex: 0 0 auto;
  }

  .dashboard-life-label {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    font-size: 8.5px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #315173;
  }

  .dashboard-life-value {
    margin-top: 0;
    overflow: hidden;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    white-space: normal;
    font-size: 10.75px;
    font-weight: 700;
    line-height: 1.08;
    text-align: left;
    color: #0b2d57;
  }

  .dashboard-floating-move,
  .dashboard-floating-resize,
  .dashboard-floating-reset {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(100, 116, 139, 0.26);
    background: rgba(255, 255, 255, 0.68);
    color: #334155;
    box-shadow: 0 8px 20px rgba(15, 23, 42, 0.12);
    backdrop-filter: blur(8px) saturate(1.08);
    touch-action: none;
  }

  .dashboard-floating-move,
  .dashboard-floating-resize {
    position: absolute;
    z-index: 6;
    opacity: 0.72;
    transition: opacity 140ms ease, transform 140ms ease, background 140ms ease;
  }

  .dashboard-floating-tile:hover .dashboard-floating-move,
  .dashboard-floating-tile:focus-within .dashboard-floating-move,
  .dashboard-floating-tile:hover .dashboard-floating-resize,
  .dashboard-floating-tile:focus-within .dashboard-floating-resize {
    opacity: 1;
  }

  .dashboard-floating-move {
    top: -10px;
    right: -10px;
    width: 30px;
    height: 30px;
    border-radius: 999px;
    cursor: grab;
  }

  .dashboard-floating-move:active {
    cursor: grabbing;
    transform: scale(0.96);
  }

  .dashboard-floating-resize {
    right: -8px;
    bottom: -8px;
    width: 26px;
    height: 26px;
    border-radius: 8px;
    cursor: nwse-resize;
  }

  .dashboard-floating-reset {
    width: 32px;
    height: 32px;
    border-radius: 8px;
  }

  @media (max-width: 900px) {
    .dashboard-floating-lobby,
    .dashboard-floating-stage {
      height: clamp(520px, calc(100dvh - 136px), 900px);
      max-height: calc(100dvh - 136px);
      min-height: 0;
    }

    .dashboard-life-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .dashboard-floating-move,
    .dashboard-floating-resize {
      opacity: 0.95;
    }
  }

  .aios-room-planning .aios-workbench,
  .aios-room-planning .aios-iframe-shell {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.72), rgba(239, 246, 255, 0.46)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.08), rgba(245, 158, 11, 0.06));
    border-color: rgba(236, 247, 255, 0.68);
    box-shadow: 0 28px 86px rgba(15, 23, 42, 0.16), inset 0 1px 0 rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(10px) saturate(1.08);
  }

  .aios-room-planning .aios-workbench > .flex,
  .aios-room-planning .aios-control-bar {
    background: rgba(255, 255, 255, 0.66);
    color: #0f172a;
    backdrop-filter: blur(12px) saturate(1.06);
  }

  .aios-room-planning .aios-iframe-shell > div {
    background:
      radial-gradient(circle at 50% 35%, rgba(14, 165, 233, 0.12), transparent 32%),
      rgba(255, 255, 255, 0.28);
  }

  .planning-room-page {
    color: #0f172a;
  }

  .planning-room-header {
    border: 1px solid rgba(236, 247, 255, 0.7);
    border-radius: 8px;
    padding: 12px 14px;
    margin-bottom: 12px;
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.76), rgba(239, 246, 255, 0.46)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.12), rgba(245, 158, 11, 0.08));
    box-shadow: 0 18px 52px rgba(15, 23, 42, 0.12), inset 0 1px 0 rgba(255, 255, 255, 0.78);
    backdrop-filter: blur(14px) saturate(1.08);
  }

  .planning-whiteboard {
    position: relative;
    border-color: rgba(226, 232, 240, 0.82) !important;
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.76), rgba(248, 250, 252, 0.46)),
      linear-gradient(90deg, rgba(14, 165, 233, 0.08), rgba(245, 158, 11, 0.06)) !important;
  }

  .planning-whiteboard::before {
    content: '';
    position: absolute;
    inset: 10px;
    pointer-events: none;
    border-radius: 6px;
    background-image:
      linear-gradient(rgba(14, 165, 233, 0.055) 1px, transparent 1px),
      linear-gradient(90deg, rgba(15, 23, 42, 0.04) 1px, transparent 1px);
    background-size: 42px 42px;
    opacity: 0.72;
  }

  .planning-whiteboard > * {
    position: relative;
    z-index: 1;
  }

  .planning-whiteboard .text-text-primary {
    color: #0f172a !important;
  }

  .planning-whiteboard .text-text-secondary {
    color: #334155 !important;
  }

  .planning-whiteboard .text-text-muted {
    color: #64748b !important;
  }

  .planning-control-strip {
    color: #0f172a;
  }

  .planning-control-strip .input {
    background: rgba(255, 255, 255, 0.68);
    color: #0f172a;
    border-color: rgba(148, 163, 184, 0.34);
  }

  .aios-room-wellness .aios-command-hero,
  .aios-room-wellness .aios-panel,
