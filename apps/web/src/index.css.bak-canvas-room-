  .aios-room-aiops .card {
    background:
      linear-gradient(145deg, rgba(255, 255, 255, 0.72), rgba(239, 246, 255, 0.46)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.1), rgba(255, 209, 102, 0.06));
    color: #0f172a;
  }

  .aios-room-mailroom .text-text-primary,
  .aios-room-revenue .text-text-primary,
  .aios-room-schedule .text-text-primary,
  .aios-room-broadcast .text-text-primary,
  .aios-room-archive .text-text-primary,
  .aios-room-control .text-text-primary,
  .aios-room-aiops .text-text-primary {
    color: #0f172a !important;
  }

  .aios-room-mailroom .text-text-secondary,
  .aios-room-revenue .text-text-secondary,
  .aios-room-schedule .text-text-secondary,
  .aios-room-broadcast .text-text-secondary,
  .aios-room-archive .text-text-secondary,
  .aios-room-control .text-text-secondary,
  .aios-room-aiops .text-text-secondary {
    color: #334155 !important;
  }

  .aios-room-mailroom .text-text-muted,
  .aios-room-revenue .text-text-muted,
  .aios-room-schedule .text-text-muted,
  .aios-room-broadcast .text-text-muted,
  .aios-room-archive .text-text-muted,
  .aios-room-control .text-text-muted,
  .aios-room-aiops .text-text-muted {
    color: #64748b !important;
  }

  .aios-panel,
  .card {
    border: 1px solid rgba(148, 177, 214, 0.2);
    border-radius: 8px;
    background:
      linear-gradient(145deg, rgba(8, 13, 28, 0.72), rgba(10, 17, 34, 0.58)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.08), rgba(255, 209, 102, 0.035));
    box-shadow: 0 18px 48px rgba(0, 0, 0, 0.26), inset 0 1px 0 rgba(255, 255, 255, 0.05);
    backdrop-filter: blur(14px) saturate(1.08);
  }

  .card-header {
    @apply px-5 py-4;
    border-bottom: 1px solid rgba(148, 177, 214, 0.18);
  }

  .card-body {
    @apply p-5;
  }

  .aios-workbench,
  .aios-iframe-shell {
    min-height: 0;
    overflow: hidden;
    border: 1px solid rgba(148, 177, 214, 0.22);
    border-radius: 8px;
    background: rgba(5, 10, 23, 0.58);
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.32), inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(14px) saturate(1.05);
  }

  .office-room-grid {
    grid-template-columns: minmax(0, 1fr);
    align-content: start;
  }

  .office-room-grid > * {
    min-width: 0;
  }

  .office-room-grid > section {
    justify-content: flex-start;
  }

  @media (min-width: 1024px) {
    .office-room-grid {
      grid-template-columns: 280px minmax(0, 1fr) 320px;
      align-content: stretch;
    }

    .office-room-grid > section {
      justify-content: flex-end;
    }
  }

  .aios-control-bar {
    border: 1px solid rgba(148, 177, 214, 0.18);
    border-radius: 8px;
    background: rgba(8, 13, 28, 0.72);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
    backdrop-filter: blur(18px);
  }

  .aios-stat {
    border: 1px solid rgba(148, 177, 214, 0.16);
    border-radius: 8px;
    background: linear-gradient(145deg, rgba(11, 19, 38, 0.78), rgba(8, 13, 28, 0.62));
  }

  .aios-segment {
    display: inline-flex;
    align-items: center;
    overflow: hidden;
    border: 1px solid rgba(148, 177, 214, 0.2);
    border-radius: 8px;
    background: rgba(5, 10, 23, 0.62);
  }

  .aios-frame-loading {
    background:
      linear-gradient(135deg, rgba(5, 10, 23, 0.94), rgba(11, 19, 38, 0.9)),
      linear-gradient(90deg, rgba(45, 212, 255, 0.08), rgba(255, 209, 102, 0.08));
    backdrop-filter: blur(18px);
  }

  .btn {
    @apply inline-flex items-center gap-2 px-3.5 py-2 rounded-lg text-sm font-medium
           transition-colors duration-150 focus:outline-none focus:ring-2 focus:ring-info/40
           disabled:opacity-50 disabled:cursor-not-allowed;
  }

  .btn-primary {
    @apply btn text-[#06101d];
    background: linear-gradient(135deg, var(--v-cyan), var(--v-gold));
    box-shadow: 0 12px 30px rgba(45, 212, 255, 0.18);
  }

  .btn-secondary {
    @apply btn text-text-primary;
    border: 1px solid rgba(148, 177, 214, 0.24);
    background: rgba(13, 23, 43, 0.72);
  }

  .btn-ghost {
    @apply btn text-text-secondary hover:text-text-primary;
    background: transparent;
  }

  .btn-danger {
    @apply btn bg-danger/10 hover:bg-danger/20 text-danger;
    border: 1px solid rgba(232, 74, 106, 0.32);
  }

  .badge {
    @apply inline-flex items-center gap-1 px-2 py-0.5 rounded-md text-xs font-medium;
  }

  .badge-success {
    @apply badge bg-success/10 text-success;
  }

  .badge-warning {
    @apply badge bg-warning/10 text-warning;
  }

  .badge-danger {
    @apply badge bg-danger/10 text-danger;
  }

  .badge-info {
    @apply badge bg-info/10 text-info;
  }

  .badge-neutral {
    @apply badge text-text-secondary;
    background: rgba(13, 23, 43, 0.78);
  }

  .input {
    @apply w-full rounded-lg px-3.5 py-2
           text-sm text-text-primary placeholder-text-muted
           focus:outline-none focus:ring-2 focus:ring-info/40
           transition-colors duration-150;
    border: 1px solid rgba(148, 177, 214, 0.22);
    background: rgba(5, 10, 23, 0.74);
  }

  .select {
    @apply input appearance-none cursor-pointer;
  }

  .status-dot {
    @apply inline-block w-2 h-2 rounded-full flex-shrink-0;
  }

  .status-dot-healthy {
    @apply status-dot bg-success;
  }

  .status-dot-degraded {
    @apply status-dot bg-warning animate-pulse-slow;
  }

  .status-dot-unhealthy {
    @apply status-dot bg-danger animate-pulse;
  }

  .status-dot-unknown {
    @apply status-dot bg-text-muted;
  }
}
