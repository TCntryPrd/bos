/** Strip the "Name <email>" decoration; fall back to the raw value. */
function senderName(raw: string): string {
  if (!raw) return 'unknown';
  const m = raw.match(/^"?([^"<]+?)"?\s*<.+>$/);
  return (m?.[1] ?? raw).trim();
}

const INBOX_HUES = ['#FF4D8D', '#0EA5E9', '#7C3CFF', '#20B26B', '#FF8A3D', '#d6b6ff'];

function inboxHue(id: string): string {
  let h = 0;
  for (let i = 0; i < id.length; i++) h = (h * 31 + id.charCodeAt(i)) >>> 0;
  return INBOX_HUES[h % INBOX_HUES.length];
}

