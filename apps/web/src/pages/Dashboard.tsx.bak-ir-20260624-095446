// least one task with a due_at falling in today's range.
interface CalendarEvent {
  id: string;
  summary: string;
  description: string | null;
  start: string;
  end: string;
  allDay: boolean;
  account: string;
  calendarName: string;
  htmlLink?: string | null;
}

interface CalendarState {
  list: CalendarEvent[];
  loaded: boolean;
}

function useCalendarToday(): CalendarState {
  const [state, setState] = useState<CalendarState>({ list: [], loaded: false });
  usePoll(() => {
    const today = new Date();
    const yyyy = today.getFullYear();
    const mm = String(today.getMonth() + 1).padStart(2, '0');
    const dd = String(today.getDate()).padStart(2, '0');
    const day = `${yyyy}-${mm}-${dd}`;
        authedFetch(`api/calendar/events?start=${day}&end=${day}`)
      .then((r) => (r.ok ? r.json() : { events: [] }))
      .then((data: { events?: CalendarEvent[] }) => {
        // Dedupe the same event appearing on multiple calendars/accounts so it
        // shows once (not 15× across 15 calendars). Key on summary+start.
        const raw = Array.isArray(data?.events) ? data.events : [];
        const seen = new Set<string>();
        const list = raw.filter((e) => {
          const key = `${(e.summary || '').trim().toLowerCase()}|${e.start}`;
          if (seen.has(key)) return false;
          seen.add(key);
          return true;
        });
        setState({ list, loaded: true });
      })
      .catch(() => setState((s) => ({ ...s, loaded: true }))); // keep last on poll error
  });
  return state;
}

// Slack user IDs we care about on the dashboard preview. Mentions of
// either Kevin or Sodapop pass the filter; everything else is hidden.
// Persisted in runtime_config (SLACK_KEVIN_USER_ID, SLACK_BOT_USER_ID).
const SLACK_KEVIN_USER_ID = 'U0940RBRLPN';
const SLACK_SODAPOP_USER_ID = 'U0B26SZ7CCT';

function isMentionOfInterest(it: SlackAttentionItem): boolean {
  // Sodapop's slack-socket flags app_mention with reason='mentioned the bot'.
  if (it.reason === 'mentioned the bot') return true;
  // DMs are implicitly to Kevin — always pass.
  if (it.reason === 'direct message') return true;
  const p = it.preview || '';
  return p.includes(`<@${SLACK_KEVIN_USER_ID}>`) || p.includes(`<@${SLACK_SODAPOP_USER_ID}>`);
}

function useSlackAttention(): SlackAttentionState {
  const [state, setState] = useState<SlackAttentionState>({ list: [], loaded: false });
  const seenIdsRef = React.useRef<Set<string>>(new Set());
  const firstLoadRef = React.useRef<boolean>(true);

  // Ask once for browser-notification permission. Browser quietly denies
  // if previously dismissed; we don't pester.
  useEffect(() => {
    if (typeof window === 'undefined' || !('Notification' in window)) return;
    if (Notification.permission === 'default') {
      void Notification.requestPermission().catch(() => { /* user dismissed */ });
    }
  }, []);

  useEffect(() => {
    let cancelled = false;
    const load = () => {
      authedFetch('api/slack/attention?status=open&limit=20')
        .then((r) => (r.ok ? r.json() : { items: [] }))
        .then((data: { items?: SlackAttentionItem[] }) => {
          if (cancelled) return;
          const raw = Array.isArray(data?.items) ? data.items : [];
          const items = raw.filter(isMentionOfInterest);

          // Browser-notify items we haven't seen before, but only after
          // the first load completes — otherwise reloading the page
          // would notify for every existing open item.
          if (!firstLoadRef.current && typeof window !== 'undefined' && 'Notification' in window) {
            if (Notification.permission === 'granted') {
              for (const it of items) {
                if (seenIdsRef.current.has(it.id)) continue;
                try {
                  const n = new Notification(`Slack — ${it.userName ?? 'unknown'}`, {
                    body: it.preview.slice(0, 140) || it.reason || 'New message',
                    tag: `slack-attn-${it.id}`,
                    icon: '/boss/ui/favicon.ico',
                  });
                  if (it.permalink) {
                    n.onclick = () => {
                      window.open(it.permalink as string, '_blank');
                      n.close();
                    };
                  }
                } catch { /* notification failed; skip */ }
              }
            }
          }

          // Mark all current items as seen for next tick
          seenIdsRef.current = new Set(items.map((i) => i.id));
          firstLoadRef.current = false;
          setState({ list: items, loaded: true });
        })
        .catch(() => { if (!cancelled) setState((s) => ({ ...s, loaded: true })); }); // keep last on poll error
    };
    load();
    const id = window.setInterval(load, 15_000); // 15s poll
    return () => { cancelled = true; window.clearInterval(id); };
  }, []);

  return state;
}

function useInbox(): InboxState {
  const [state, setState] = useState<InboxState>({ list: [], email: null, loaded: false });
  usePoll(() => {
    // The Email Agent's triaged attention items (boss_email_log, needs_attention) —
    // what the agent flagged for Kevin, with its category + note. This is the
    // agent's output, not raw Gmail.
    authedFetch('api/email/attention')
      .then((r) => (r.ok ? r.json() : []))
      .then((data: unknown) => {
        const arr = Array.isArray(data) ? (data as Array<Record<string, unknown>>) : [];
        const list: InboxAttentionItem[] = arr.map((x) => {
          const msgId = x.messageId ? String(x.messageId) : '';
          const acct = x.accountEmail ? String(x.accountEmail) : '';
          const gmailUrl = msgId
            ? (acct
                ? `https://mail.google.com/mail/?authuser=${encodeURIComponent(acct)}#all/${msgId}`
                : `https://mail.google.com/mail/u/0/#all/${msgId}`)
            : undefined;
          return {
            id: String(x.id ?? ''),
            sender: String(x.sender ?? ''),
            subject: String(x.subject ?? ''),
            timestamp: String(x.receivedAt ?? ''),
            preview: String(x.bossNotes ?? ''),
            category: x.category ? String(x.category) : undefined,
            gmailUrl,
          };
        });
        setState({ list, email: null, loaded: true });
      })
      .catch(() => setState((s) => ({ ...s, loaded: true }))); // keep last on poll error
  });
  return state;
}

function useWhatsApp(): WhatsAppState {
  const [state, setState] = useState<WhatsAppState>({ list: [], loaded: false });
  useEffect(() => {
    let cancelled = false;
    const load = () => {
      authedFetch('api/whatsapp/threads')
        .then((r) => (r.ok ? r.json() : { threads: [] }))
        .then((data: { threads?: WhatsAppThread[] }) => {
          if (cancelled) return;
