/**
 * Rascals — autonomous per-target agents wired to the Pipeline Engine.
 *
 * Card grid layout. Each rascal gets a hue avatar, display name + handle,
 * client, CLI badge, enable toggle, project-dir line. New "+ Add rascal"
 * action opens a creation form so any tmux-backed CC/Ollama agent can be
 * registered through the UI rather than via SQL or scripts.
 *
 * Note: the COO is BOS itself (this operator), not a Rascal. The /coo
 * surface lives at apps/web/src/pages/COO.tsx and is unrelated to this list.
 */

import React, { useCallback, useEffect, useMemo, useState } from 'react';
import { Link } from 'react-router-dom';
import {
  Users,
  RefreshCw,
  CheckCircle2,
  CircleOff,
  Bot,
  Terminal,
  Plus,
  X,
  Folder,
} from 'lucide-react';
import { PageLoader } from '../components/LoadingSpinner';
import { EmptyState } from '../components/EmptyState';
import { AgentAvatar, agentHue } from '../components/AgentAvatar';

interface Rascal {
  tenantId: string;
  handle: string;
  displayName: string;
  cli: 'claude' | 'ollama';
  client: string;
  projectDir: string;
  enabled: boolean;
  createdAt: string;
  updatedAt: string;
}

function authHeaders(): HeadersInit {
  const token = localStorage.getItem('boss_token') ?? '';
  return token ? { Authorization: `Bearer ${token}` } : {};
}

async function fetchRascals(): Promise<Rascal[]> {
  const res = await fetch('api/agents/rascals', { headers: authHeaders() });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
  const body = (await res.json()) as { rascals: Rascal[] };
  return body.rascals;
}

async function patchRascal(handle: string, patch: Partial<Pick<Rascal, 'enabled'>>): Promise<void> {
  const res = await fetch(`api/agents/rascals/${handle}`, {
    method: 'PATCH',
    headers: { 'Content-Type': 'application/json', ...authHeaders() },
    body: JSON.stringify(patch),
  });
  if (!res.ok) throw new Error(`HTTP ${res.status}`);
}

interface CreateBody {
  handle: string;
  displayName: string;
  cli: 'claude' | 'ollama';
  client: string;
  projectDir: string;
  enabled: boolean;
}

async function createRascal(body: CreateBody): Promise<void> {
  const res = await fetch('api/agents/rascals', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json', ...authHeaders() },
    body: JSON.stringify(body),
  });
  if (!res.ok) {
    const data = await res.json().catch(() => ({}));
    throw new Error((data as { message?: string }).message ?? `HTTP ${res.status}`);
  }
}

interface RascalCardProps {
  rascal: Rascal;
  pending: boolean;
  onToggle: () => void;
}

function RascalCard({ rascal, pending, onToggle }: RascalCardProps) {
  const hue = agentHue(rascal.handle);
  return (
    <Link
      to={`/rascals/${rascal.handle}`}
      className="relative rounded-xl border border-border bg-surface-1/70 p-4 flex flex-col gap-3 hover:border-border-strong transition-colors block"
      style={{ backdropFilter: 'blur(10px)' }}
      data-testid="rascal-card"
    >
      <div
        className="absolute top-0 left-4 right-4 h-px"
        style={{ background: `linear-gradient(90deg, transparent, ${hue}66, transparent)` }}
        aria-hidden
      />
      <div className="flex items-start gap-3">
        <AgentAvatar handle={rascal.handle} displayName={rascal.displayName} size={44} ring />
        <div className="flex-1 min-w-0">
          <div className="text-[14px] font-semibold text-text-primary leading-tight">{rascal.displayName}</div>
          <div className="vs-mono text-[11px] mt-0.5 text-text-muted truncate">{rascal.handle}</div>
        </div>
        <button
          type="button"
          onClick={(e) => { e.preventDefault(); e.stopPropagation(); onToggle(); }}
          disabled={pending}
          className={`flex items-center gap-1 text-[11px] font-medium px-2 py-1 rounded-md transition-colors ${
            rascal.enabled ? 'bg-success/15 text-success border border-success/40' : 'bg-surface-2 text-text-muted border border-border hover:text-text-primary'
          } disabled:opacity-50`}
          aria-label={rascal.enabled ? 'Disable rascal' : 'Enable rascal'}
        >
          {rascal.enabled ? <CheckCircle2 className="w-3.5 h-3.5" /> : <CircleOff className="w-3.5 h-3.5" />}
          {rascal.enabled ? 'Enabled' : 'Disabled'}
        </button>
      </div>
      <div className="grid grid-cols-2 gap-x-3 gap-y-2 text-[11.5px]">
        <div>
          <div className="vs-mono text-[9px] uppercase tracking-[0.2em] text-text-muted">Client</div>
          <div className="text-text-primary truncate mt-0.5">{rascal.client || '—'}</div>
        </div>
        <div>
          <div className="vs-mono text-[9px] uppercase tracking-[0.2em] text-text-muted">CLI</div>
          <div className="flex items-center gap-1 mt-0.5">
            {rascal.cli === 'claude' ? <Bot className="w-3 h-3" /> : <Terminal className="w-3 h-3" />}
            <span className="text-text-primary">{rascal.cli}</span>
          </div>
        </div>
      </div>
      <div className="flex items-start gap-1.5 text-[11px] text-text-muted truncate">
        <Folder className="w-3 h-3 flex-shrink-0 mt-0.5" />
        <span className="font-mono truncate" title={rascal.projectDir}>{rascal.projectDir}</span>
      </div>
    </Link>
  );
}

interface CreateModalProps {
  open: boolean;
  onClose: () => void;
  onCreated: () => void;
}

function CreateModal({ open, onClose, onCreated }: CreateModalProps) {
  const [form, setForm] = useState<CreateBody>({
    handle: '',
    displayName: '',
    cli: 'claude',
    client: '',
    projectDir: '',
    enabled: true,
  });
  const [submitting, setSubmitting] = useState(false);
  const [error, setError] = useState<string | null>(null);

  useEffect(() => {
    if (open) {
      setForm({ handle: '', displayName: '', cli: 'claude', client: '', projectDir: '', enabled: true });
      setError(null);
    }
  }, [open]);

  useEffect(() => {
    if (!open) return;
    const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') onClose(); };
    document.addEventListener('keydown', onKey);
    return () => document.removeEventListener('keydown', onKey);
  }, [open, onClose]);

  if (!open) return null;

  const handleValid = /^[a-z]{2,24}$/.test(form.handle);
  const valid = handleValid && form.displayName.trim().length > 0 && form.projectDir.trim().length > 0;

  async function submit() {
    setSubmitting(true);
    setError(null);
    try {
      await createRascal(form);
      onCreated();
      onClose();
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to create');
    } finally {
      setSubmitting(false);
    }
  }

  const inputBase = 'w-full bg-surface-2/70 border border-border rounded-md px-3 py-2 text-sm text-text-primary placeholder:text-text-muted focus:outline-none focus:border-accent/60';

  return (
    <div className="fixed inset-0 z-[80] flex items-center justify-center p-6" role="dialog" aria-modal="true">
      <div className="absolute inset-0 bg-black/70 backdrop-blur-sm" onClick={onClose} />
      <div className="relative w-full max-w-md rounded-xl border border-border bg-surface-1/95 p-5 shadow-xl">
        <header className="flex items-start justify-between mb-4">
          <div>
            <div className="vs-mono text-[10px] uppercase tracking-[0.22em] text-text-muted">Action</div>
            <h2 className="text-lg font-semibold mt-1">Add rascal</h2>
          </div>
          <button type="button" onClick={onClose} className="text-text-muted hover:text-text-primary" aria-label="Close">
            <X className="w-4 h-4" />
          </button>
        </header>
        <div className="space-y-3">
          <div>
            <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">Handle</label>
            <input
              autoFocus
              className={`${inputBase} font-mono`}
              placeholder="lowercase a–z, 2–24 chars"
              value={form.handle}
              onChange={(e) => setForm((f) => ({ ...f, handle: e.target.value.trim() }))}
            />
            {!handleValid && form.handle.length > 0 && (
              <p className="text-[10.5px] text-danger mt-1">Must be lowercase letters only, 2–24 chars.</p>
            )}
          </div>
          <div>
            <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">Display name</label>
            <input
              className={inputBase}
              placeholder="e.g. Buckwheat · Acme Field Ops"
              value={form.displayName}
              onChange={(e) => setForm((f) => ({ ...f, displayName: e.target.value }))}
            />
          </div>
          <div>
            <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">Client</label>
            <input
              className={inputBase}
              placeholder="e.g. team / department"
              value={form.client}
              onChange={(e) => setForm((f) => ({ ...f, client: e.target.value }))}
            />
          </div>
          <div>
            <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">Project dir</label>
            <input
              className={`${inputBase} font-mono`}
              placeholder="/home/boss/agents/<handle>"
              value={form.projectDir}
              onChange={(e) => setForm((f) => ({ ...f, projectDir: e.target.value }))}
            />
          </div>
          <div className="grid grid-cols-2 gap-3">
            <div>
              <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">CLI</label>
              <select
                className={inputBase}
                value={form.cli}
                onChange={(e) => setForm((f) => ({ ...f, cli: e.target.value as 'claude' | 'ollama' }))}
              >
                <option value="claude">claude</option>
                <option value="ollama">ollama</option>
              </select>
            </div>
            <div>
              <label className="block text-[11px] vs-mono uppercase tracking-wider text-text-muted mb-1">Enabled</label>
              <button
                type="button"
                onClick={() => setForm((f) => ({ ...f, enabled: !f.enabled }))}
                className={`w-full px-3 py-2 rounded-md text-sm border ${form.enabled ? 'bg-success/15 text-success border-success/40' : 'bg-surface-2 text-text-muted border-border'}`}
              >
                {form.enabled ? 'enabled' : 'disabled'}
              </button>
            </div>
          </div>
          {error && <p className="text-[12px] text-danger">{error}</p>}
        </div>
        <footer className="flex items-center justify-end gap-2 mt-5 pt-4 border-t border-border">
          <button type="button" onClick={onClose} className="text-[12px] text-text-muted hover:text-text-primary px-3 py-1.5">Cancel</button>
          <button
            type="button"
            onClick={() => void submit()}
            disabled={!valid || submitting}
            className="text-[12px] font-semibold text-[#0a0c12] px-4 py-1.5 rounded-md disabled:opacity-50"
            style={{ background: 'linear-gradient(135deg, #b56cff 0%, #5cc8ff 100%)' }}
          >
            {submitting ? 'Creating…' : 'Create rascal'}
          </button>
        </footer>
      </div>
    </div>
  );
}

export function Rascals() {
  const [rascals, setRascals] = useState<Rascal[] | null>(null);
  const [error, setError] = useState<string | null>(null);
  const [loading, setLoading] = useState(false);
  const [pending, setPending] = useState<Record<string, boolean>>({});
  const [createOpen, setCreateOpen] = useState(false);

  const refresh = useCallback(async () => {
    setLoading(true);
    try {
      setRascals(await fetchRascals());
      setError(null);
    } catch (err) {
      setError(err instanceof Error ? err.message : 'Failed to load rascals');
    } finally {
      setLoading(false);
    }
  }, []);

  useEffect(() => {
    void refresh();
  }, [refresh]);

  const toggleEnabled = useCallback(async (r: Rascal) => {
    setPending((p) => ({ ...p, [r.handle]: true }));
    try {
      await patchRascal(r.handle, { enabled: !r.enabled });
      await refresh();
    } finally {
      setPending((p) => {
        const next = { ...p };
        delete next[r.handle];
        return next;
      });
    }
  }, [refresh]);

  const enabledCount = useMemo(() => rascals?.filter((r) => r.enabled).length ?? 0, [rascals]);

  if (!rascals && loading) return <PageLoader />;

  return (
    <div className="flex-1 p-5 lg:p-6 space-y-5">
      <header className="flex items-end gap-4 justify-between">
        <div>
          <div className="vs-mono text-[10px] uppercase tracking-[0.28em] text-text-muted">SURFACE / RASCALS</div>
          <h1 className="text-2xl font-semibold mt-1 flex items-center gap-2 text-text-primary">
            <Users className="w-6 h-6 text-accent" />
            Rascals
          </h1>
          <p className="text-[12.5px] text-text-secondary mt-1">
            Per-target autonomous agents · cron-fired each weekday morning · backed by tmux sessions on this host.
            {rascals ? ` ${enabledCount} of ${rascals.length} enabled.` : ''}
          </p>
        </div>
        <div className="flex items-center gap-2">
          <button
            type="button"
            onClick={() => void refresh()}
            disabled={loading}
            className="vs-chip disabled:opacity-50"
            aria-label="Refresh"
          >
            <RefreshCw className={`w-3 h-3 ${loading ? 'animate-spin' : ''}`} />
            Refresh
          </button>
          <button
            type="button"
            onClick={() => setCreateOpen(true)}
            className="text-[12px] font-semibold text-[#0a0c12] px-3 py-1.5 rounded-md inline-flex items-center gap-1.5"
            style={{ background: 'linear-gradient(135deg, #b56cff 0%, #5cc8ff 100%)', boxShadow: '0 0 14px rgba(181,108,255,0.25)' }}
          >
            <Plus className="w-3.5 h-3.5" />
            Add rascal
          </button>
        </div>
      </header>

      {error ? (
        <div className="rounded-xl border border-danger/40 bg-danger/10 p-4 text-[13px] text-danger">
          Failed to load: {error}
        </div>
      ) : !rascals || rascals.length === 0 ? (
        <EmptyState
          icon={<Users className="w-12 h-12" />}
          title="No agents registered yet"
          description="Click + Add rascal to register a tmux-backed per-target agent (CC or Ollama)."
        />
      ) : (
        <div
          data-testid="rascals-grid"
          data-rascal-capacity="12"
          className="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 2xl:grid-cols-4 gap-3"
        >
          {rascals.map((r) => (
            <RascalCard
              key={r.handle}
              rascal={r}
              pending={!!pending[r.handle]}
              onToggle={() => void toggleEnabled(r)}
            />
          ))}
        </div>
      )}

      <CreateModal open={createOpen} onClose={() => setCreateOpen(false)} onCreated={() => void refresh()} />
    </div>
  );
}
