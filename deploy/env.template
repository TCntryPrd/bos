# IR White-Label IR Custom AIOS - Environment Configuration
# Generated for Kane Minkus deployment on Hostinger
# IMPORTANT: Generate fresh encryption keys before deployment!

# Node Environment
NODE_ENV=production
PORT=8001

# Multi-Tenancy Configuration (WHITE-LABEL MODE)
TENANT_MODE=multi
DEFAULT_TENANT_ID=303f28e3-4ee1-4b73-bd76-5d0b84d5f5b9
INSTALL_ENABLED=true
INSTALL_REQUIRE_INVITE=false

# Database (Update with Hostinger PostgreSQL credentials)
POSTGRES_USER=boss
POSTGRES_DB=boss_ir
POSTGRES_URL=postgresql://${POSTGRES_USER}:__POSTGRES_PASSWORD__@postgres:5432/${POSTGRES_DB}
POSTGRES_PORT=5432

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Weaviate Vector Database
WEAVIATE_URL=http://weaviate:8080

# Security - GENERATE FRESH KEYS!
# Generate with: openssl rand -hex 32
BOSS_TOKEN_ENCRYPTION_KEY=__BOSS_TOKEN_ENCRYPTION_KEY__
JWT_SECRET=__JWT_SECRET__

# API Configuration
API_BASE_URL=https://__DOMAIN__

# Trusted IPs for internal auth bypass
BOSS_INTERNAL_TRUSTED_IPS=127.0.0.1,::1,172.22.0.1,172.16.2.1

# Trusted proxies (Docker network)
BOSS_TRUSTED_PROXIES=172.22.0.0/16

# STT Service
STT_URL=http://stt:8000
WHISPER_MODEL=base
WHISPER_COMPUTE_TYPE=int8

# Background Agents (Enable after initial setup)
BOSS_BACKGROUND_AGENTS=off

# === CONNECTOR CREDENTIALS ===
# These should be configured by Kane during /install onboarding
# Left blank for clean deployment

# Telegram (optional)
TELEGRAM_BOT_TOKEN=

# OpenRouter for LLM access (Kane will provide during install)
OPENROUTER_API_KEY=

# Note: Gmail, Google Calendar, Slack, etc. are configured via MCP OAuth
# during the onboarding flow - no env vars needed here
POSTGRES_PASSWORD=__POSTGRES_PASSWORD__
BOSS_TOKEN_ENCRYPTION_KEY=__BOSS_TOKEN_ENCRYPTION_KEY__
JWT_SECRET=__JWT_SECRET__
OPENWA_API_KEY=
GEMINI_MODEL=gemma-4-26b-a4b-it
BOSS_JWT_SECRET=__BOSS_JWT_SECRET__
BOSS_CHAT_RUNNER=local
BOSS_RUNTIME=docker
