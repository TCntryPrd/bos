// Sales tile — a clean stats roll-up of #sales-event-stats: a prominent Today
// block (revenue + count), an All / Event row (revenue, count, avg deal), a
// short Top reps list, and a tiny recent-sales strip. Self-fetching via
// usePolledJson (15s), keeps last good data on a transient error so it never
// blanks mid-day.
// Funnel stages rendered per event, in attendance order. "End" falls back to
// the "close" count when the post used Close instead of End.
const FUNNEL_STAGES: { key: string; label: string; alt?: string }[] = [
  { key: 'start', label: 'Start' },
  { key: 'peak', label: 'Peak' },
  { key: 'offer', label: 'Offer' },
  { key: 'link', label: 'Link' },
  { key: 'end', label: 'End', alt: 'close' },
];

/** A number that's actually present (non-null) on a stages record. */
function stageVal(stages: Record<string, number | null>, key: string, alt?: string): number | null {
  const v = stages[key];
  if (v !== null && v !== undefined) return v;
  if (alt) {
    const a = stages[alt];
    if (a !== null && a !== undefined) return a;
  }
  return null;
}

interface LinkedInStatusT { connected: boolean; email?: string; expiresAt?: string | null; }
interface LinkedInPostT { id: string; text: string; link: string | null; post_id: string | null; posted_at: string; }

function LinkedInPanel() {
  const { data: status, loaded } = usePolledJson<LinkedInStatusT>('api/linkedin/status', 30_000);
  const { data: postsData } = usePolledJson<{ posts: LinkedInPostT[] }>('api/linkedin/posts', 30_000);
  const posts = postsData?.posts ?? [];
  const connected = !!status?.connected;
  const [text, setText] = useState('');
  const [link, setLink] = useState('');
  const [busy, setBusy] = useState(false);
  const [msg, setMsg] = useState<{ ok: boolean; text: string } | null>(null);
  const [media, setMedia] = useState<{ name: string; mtype: 'image' | 'video' | 'document'; b64: string } | null>(null);

  function onPickFile(f: File | null) {
    if (!f) { setMedia(null); return; }
    const mtype: 'image' | 'video' | 'document' = f.type.startsWith('image/') ? 'image' : f.type.startsWith('video/') ? 'video' : 'document';
    const reader = new FileReader();
    reader.onload = () => setMedia({ name: f.name, mtype, b64: String(reader.result) });
    reader.readAsDataURL(f);
  }

  async function publish() {
    if ((!text.trim() && !media) || busy) return;
    setBusy(true); setMsg(null);
    try {
      const token = localStorage.getItem('boss_token') ?? '';
      const r = await fetch('api/linkedin/post', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', ...(token ? { Authorization: `Bearer ${token}` } : {}) },
        body: JSON.stringify({
          text: text.trim(),
          link: link.trim() || undefined,
          media: media ? { type: media.mtype, dataBase64: media.b64, filename: media.name } : undefined,
        }),
      });
      const d = await r.json().catch(() => ({})) as { error?: string };
      if (r.ok) { setMsg({ ok: true, text: 'Posted to LinkedIn.' }); setText(''); setLink(''); setMedia(null); }
      else setMsg({ ok: false, text: d.error || `Failed (${r.status})` });
    } catch (e) {
      setMsg({ ok: false, text: e instanceof Error ? e.message : 'Failed to post' });
    } finally { setBusy(false); }
  }

  const inputStyle = { background: 'rgba(255,255,255,0.04)', border: `1px solid ${DASH.borderSoft}`, color: DASH.text } as const;

  return (
    <Panel
      title="LinkedIn"
      icon={<Linkedin size={14} />}
      accent="linear-gradient(135deg, #0A66C2, #4F9BE8)"
      meta={
        <span className="vs-mono text-[10px]" style={{ color: connected ? DASH.green : DASH.textMuted }}>
          {!loaded ? 'LOADING…' : connected ? `CONNECTED${status?.email ? ' · ' + status.email : ''}` : 'NOT CONNECTED'}
        </span>
      }
    >
      <div className="px-3.5 py-3 space-y-2.5">
        {!connected ? (
          <div className="text-[12px]" style={{ color: DASH.textMuted }}>
            Connect LinkedIn in Settings → Connections to post.
          </div>
        ) : (
          <>
            <textarea
              value={text}
              onChange={(e) => setText(e.target.value)}
              placeholder="Write a LinkedIn post…"
              rows={3}
              maxLength={3000}
              className="w-full resize-none rounded-md px-2.5 py-2 text-[12.5px] outline-none"
              style={inputStyle}
            />
            <input
              value={link}
              onChange={(e) => setLink(e.target.value)}
              placeholder="Optional link (https://…)"
              className="w-full rounded-md px-2.5 py-1.5 text-[11.5px] outline-none"
              style={inputStyle}
            />
            <div className="flex items-center gap-2">
              <label className="inline-flex items-center gap-1.5 text-[11px] cursor-pointer rounded-md px-2 py-1" style={{ color: DASH.textMuted, border: `1px solid ${DASH.borderSoft}` }}>
                <input
                  type="file"
                  accept="image/*,video/*,.pdf,.doc,.docx,.ppt,.pptx"
                  className="hidden"
                  onChange={(e) => onPickFile(e.target.files?.[0] ?? null)}
                />
                📎 {media ? `${media.name.slice(0, 22)}` : 'Image / video / doc'}
              </label>
              {media && (
                <button onClick={() => setMedia(null)} className="text-[11px]" style={{ color: '#F5736B' }} title="Remove attachment">✕</button>
              )}
            </div>
            <div className="flex items-center justify-between gap-2">
              <span className="vs-mono text-[10px]" style={{ color: msg ? (msg.ok ? DASH.green : '#F5736B') : DASH.textMuted }}>
                {msg ? msg.text : `${text.length}/3000`}
              </span>
              <button
                onClick={publish}
                disabled={busy || (!text.trim() && !media)}
                className="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-[12px] font-medium disabled:opacity-50"
                style={{ background: '#0A66C2', color: '#fff' }}
              >
                <Send size={12} /> {busy ? 'Posting…' : 'Post'}
              </button>
            </div>
          </>
        )}
        {posts.length > 0 && (
          <div className="pt-1.5" style={{ borderTop: `1px solid ${DASH.borderSoft}` }}>
            <div className="vs-mono text-[9px] uppercase tracking-[0.16em] pt-2 pb-1" style={{ color: DASH.textMuted }}>Recent posts</div>
            <ul className="space-y-1.5">
              {posts.slice(0, 4).map((p) => (
                <li key={p.id} className="text-[11.5px] leading-snug" style={{ color: DASH.text }}>
                  <span className="vs-mono text-[9px] mr-1.5" style={{ color: DASH.textMuted }}>
                    {new Date(p.posted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}
                  </span>
                  {p.text.slice(0, 90)}{p.text.length > 90 ? '…' : ''}
                </li>
              ))}
            </ul>
          </div>
        )}
      </div>
    </Panel>
  );
}

interface LinkedInPostFullT { id: string; text: string; post_id: string | null; media_kind: string | null; viewUrl: string | null; posted_at: string; }

function LinkedInPostsPanel() {
  const [refresh, setRefresh] = useState(0);
  const { data, loaded } = usePolledJson<{ posts: LinkedInPostFullT[] }>(`api/linkedin/posts?limit=20&v=${refresh}`, 30_000);
  const posts = data?.posts ?? [];
  const [editId, setEditId] = useState<string | null>(null);
  const [editText, setEditText] = useState('');
  const [busy, setBusy] = useState<string | null>(null);

  async function authFetch(url: string, opts: RequestInit) {
    const token = localStorage.getItem('boss_token') ?? '';
    return fetch(url, { ...opts, headers: { 'Content-Type': 'application/json', ...(token ? { Authorization: `Bearer ${token}` } : {}) } });
  }
  async function del(id: string) {
    if (busy) return; setBusy(id);
    try { await authFetch(`api/linkedin/posts/${id}`, { method: 'DELETE' }); setRefresh((v) => v + 1); }
    finally { setBusy(null); }
  }
  async function saveEdit(id: string) {
    if (busy || !editText.trim()) return; setBusy(id);
    try {
      const r = await authFetch(`api/linkedin/posts/${id}`, { method: 'PATCH', body: JSON.stringify({ text: editText.trim() }) });
      if (r.ok) { setEditId(null); setRefresh((v) => v + 1); }
    } finally { setBusy(null); }
  }

  return (
    <Panel
      title="LinkedIn Posts"
      icon={<Linkedin size={14} />}
      accent="linear-gradient(135deg, #0A66C2, #4F9BE8)"
      meta={<span className="vs-mono text-[10px]" style={{ color: DASH.textMuted }}>{!loaded ? 'LOADING…' : `${posts.length} POSTS`}</span>}
    >
      <div className="px-3.5 py-3">
        {!loaded ? (
          <div className="text-[12px]" style={{ color: DASH.textMuted }}>loading…</div>
        ) : posts.length === 0 ? (
          <div className="text-[12px]" style={{ color: DASH.textMuted }}>No posts yet — publish from the LinkedIn tile.</div>
        ) : (
          <ul className="space-y-2.5">
            {posts.map((p) => (
              <li key={p.id} className="pb-2" style={{ borderBottom: `1px solid ${DASH.borderSoft}` }}>
                {editId === p.id ? (
                  <div className="space-y-1.5">
                    <textarea
                      value={editText}
                      onChange={(e) => setEditText(e.target.value)}
                      rows={2}
                      className="w-full resize-none rounded-md px-2 py-1.5 text-[12px] outline-none"
                      style={{ background: 'rgba(255,255,255,0.04)', border: `1px solid ${DASH.borderSoft}`, color: DASH.text }}
                    />
                    <div className="flex gap-3 text-[11px]">
                      <button onClick={() => saveEdit(p.id)} disabled={busy === p.id} style={{ color: DASH.green }}>{busy === p.id ? 'Saving…' : 'Save'}</button>
                      <button onClick={() => setEditId(null)} style={{ color: DASH.textMuted }}>Cancel</button>
                    </div>
                  </div>
                ) : (
                  <>
                    <div className="text-[12px] leading-snug" style={{ color: DASH.text }}>
                      {p.text.slice(0, 160)}{p.text.length > 160 ? '…' : ''}
                      {p.media_kind && p.media_kind !== 'text' && (
                        <span className="vs-mono text-[9px] ml-1.5 px-1 rounded" style={{ background: 'rgba(10,102,194,0.18)', color: '#4F9BE8' }}>{p.media_kind}</span>
                      )}
                    </div>
                    <div className="flex items-center gap-3 mt-1 text-[10px]">
                      <span className="vs-mono" style={{ color: DASH.textMuted }}>{new Date(p.posted_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric' })}</span>
                      {p.viewUrl && <a href={p.viewUrl} target="_blank" rel="noreferrer" style={{ color: '#4F9BE8' }}>View ↗</a>}
                      <button onClick={() => { setEditId(p.id); setEditText(p.text); }} style={{ color: DASH.textMuted }}>Edit</button>
                      <button onClick={() => del(p.id)} disabled={busy === p.id} style={{ color: '#F5736B' }}>{busy === p.id ? '…' : 'Delete'}</button>
                    </div>
                  </>
                )}
              </li>
            ))}
          </ul>
        )}
      </div>
    </Panel>
  );
}

interface EmailDraftT { id: string; account: string; to_addr: string | null; subject: string | null; reply_subject: string | null; body: string; rating: number | null; rating_note: string | null; created_at: string; verdict: 'pass' | 'needs_human' | 'block' | null; verdict_issues: { severity: string; detail: string }[] | null; flags: string[] | null; }

function VerdictBadge({ verdict }: { verdict: EmailDraftT['verdict'] }) {
  if (!verdict) return null;
  const map: Record<NonNullable<EmailDraftT['verdict']>, { label: string; color: string; bg: string }> = {
    pass:        { label: 'PASS',        color: DASH.green, bg: 'rgba(60,200,140,0.15)' },
    needs_human: { label: 'NEEDS HUMAN', color: '#E2B341', bg: 'rgba(226,179,65,0.15)' },
    block:       { label: 'BLOCK',       color: '#F5736B', bg: 'rgba(245,115,107,0.16)' },
  };
  const v = map[verdict];
  return (
    <span className="vs-mono text-[9px] px-1 rounded" style={{ color: v.color, background: v.bg }}>{v.label}</span>
  );
}

