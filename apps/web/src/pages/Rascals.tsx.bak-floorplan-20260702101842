            <div className="truncate text-[11px] text-white/84">{agent.client || 'No client assigned'}</div>
            <div className="mt-2 flex items-center gap-1.5 text-[10px] text-white/58">
              {agent.cli === 'claude' ? <Bot className="h-3 w-3" /> : <Terminal className="h-3 w-3" />}
              {agent.cli}
