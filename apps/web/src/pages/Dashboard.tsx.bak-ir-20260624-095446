                  {(totals.events ? Math.round(totals.link / totals.events) : 0).toLocaleString()}
                </div>
              </div>
            </div>
            {/* Per-event funnel list */}
            <div>
              {events.map((ev, idx) => {
                const peak = stageVal(ev.stages, 'peak');
                const offer = stageVal(ev.stages, 'offer');
                const offerRate =
                  peak !== null && peak > 0 && offer !== null
                    ? Math.round((offer / peak) * 100)
                    : null;
                const name = ev.name && ev.name.length > 38 ? `${ev.name.slice(0, 38)}…` : (ev.name || 'Untitled event');
                const when = ev.date ?? (ev.postedAt ? timeAgo(ev.postedAt) : '');
                const chips = FUNNEL_STAGES
                  .map((s) => ({ label: s.label, val: stageVal(ev.stages, s.key, s.alt) }))
                  .filter((c) => c.val !== null);
                return (
                  <div
                    key={`${ev.postedAt}-${idx}`}
                    className="px-3.5 py-2.5"
                    data-slack-sales-item
                    style={{ borderTop: idx > 0 ? `1px solid ${DASH.borderSoft}` : 'none' }}
                  >
                    <div className="flex items-baseline gap-2">
                      <span className="text-[12.5px] font-medium truncate" style={{ color: DASH.text }} title={ev.name || undefined}>
                        {name}
                      </span>
                      {offerRate !== null && (
                        <span
                          className="vs-mono text-[9px] px-1.5 py-0.5 rounded-[4px] shrink-0"
                          style={{ color: DASH.green, background: 'rgba(34,197,94,0.12)' }}
                          title="offers ÷ peak attendance"
                        >
                          offer rate {offerRate}%
                        </span>
                      )}
                      {when && (
                        <span className="vs-mono text-[10px] shrink-0 ml-auto" style={{ color: DASH.textMuted }}>
                          {when}
                        </span>
                      )}
                    </div>
                    {chips.length > 0 ? (
                      <div className="flex flex-wrap gap-x-2 gap-y-0.5 mt-1">
                        {chips.map((c, i) => (
                          <span key={c.label} className="vs-mono text-[10.5px]" style={{ color: DASH.textDim }}>
                            {i > 0 && <span style={{ color: DASH.textMuted }}>· </span>}
                            {c.label} <span style={{ color: DASH.text }}>{(c.val as number).toLocaleString()}</span>
                          </span>
                        ))}
                      </div>
                    ) : (
                      <div className="vs-mono text-[10.5px] mt-1 italic" style={{ color: DASH.textMuted }}>
                        no stage data
                      </div>
                    )}
                  </div>
                );
              })}
            </div>
          </>
        )}
      </div>
    </Panel>
  );
}

