/** Format a due_at ISO string as "Today" / "Tmrw" / "Apr 28". */
function formatDue(iso: string | null): string | null {
  if (!iso) return null;
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  const today = new Date();
  const tomorrow = new Date();
  tomorrow.setDate(today.getDate() + 1);
  const sameDay = (a: Date, b: Date) =>
    a.getFullYear() === b.getFullYear() &&
    a.getMonth() === b.getMonth() &&
    a.getDate() === b.getDate();
  if (sameDay(d, today)) return 'Today';
  if (sameDay(d, tomorrow)) return 'Tmrw';
  return d.toLocaleDateString('en-US', { month: 'short', day: 'numeric' });
}

const PEEK_COLS: { id: 'today' | 'overdue' | 'tomorrow'; title: string; hue: string }[] = [
  { id: 'today',    title: 'TODAY',    hue: '#7C3CFF' },
  { id: 'overdue',  title: 'OVERDUE',  hue: '#FF8A3D' },
