{
  "name": "bos-wa-bridge",
  "version": "1.0.0",
  "private": true,
  "description": "Baileys-based WhatsApp bridge for BOS — protocol-level (no browser), same REST + webhook contract as the retired OpenWA service",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsc -p tsconfig.json && node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@whiskeysockets/baileys": "^6.7.9",
    "express": "^4.21.2",
    "pino": "^9.5.0",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.0",
    "@types/qrcode": "^1.5.5",
    "typescript": "^5.6.3"
  }
}
