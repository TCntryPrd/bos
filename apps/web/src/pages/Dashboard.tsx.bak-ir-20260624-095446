/** Convert an ISO-or-date string to a fractional hour-of-day, or null. */
function isoToHour(iso: string): number | null {
  const d = new Date(iso);
  if (Number.isNaN(d.getTime())) return null;
  return d.getHours() + d.getMinutes() / 60;
}

interface TimelineBlock {
  laneKey: string;
  label: string;
  hue: string;
  startH: number;
  endH: number;
  source: 'event' | 'task';
  href?: string;
}

/**
 * Greedy pack overlapping blocks into vertical rows so nothing renders on
 * top of anything else. Returns each block annotated with its row index
 * and the total row count needed for the lane.
 *
 * Used by the timeline lanes (especially "You", which can have stacked
 * meetings) so a busy day grows downward instead of overlapping.
 */
function packBlocksIntoRows(blocks: TimelineBlock[]): {
  packed: Array<TimelineBlock & { row: number }>;
  rowCount: number;
} {
  const sorted = [...blocks].sort((a, b) => a.startH - b.startH || a.endH - b.endH);
  const rowEnds: number[] = []; // row index → end hour of last block placed
  const packed = sorted.map((b) => {
    let row = rowEnds.findIndex((end) => end <= b.startH);
    if (row === -1) {
      row = rowEnds.length;
      rowEnds.push(b.endH);
    } else {
      rowEnds[row] = b.endH;
    }
    return { ...b, row };
  });
  return { packed, rowCount: Math.max(1, rowEnds.length) };
}

interface TimelinePanelProps {
  calendar: CalendarState;
  tasks: TasksState;
  rascals: RascalsState;
}

function TimelinePanel({ calendar, tasks, rascals }: TimelinePanelProps) {
  // Visible window. Could be config later; design uses 8 AM - 5:30 PM.
  const startH = 8;
  const endH = 17.5;
  const hours = Array.from({ length: 10 }, (_, i) => startH + i);
  const pct = (h: number) => ((h - startH) / (endH - startH)) * 100;

  const today = new Date();
  const isToday = (iso: string | null): boolean => {
    if (!iso) return false;
    const d = new Date(iso);
    return (
      d.getFullYear() === today.getFullYear() &&
      d.getMonth() === today.getMonth() &&
      d.getDate() === today.getDate()
    );
  };

  // Live "now" marker — a red vertical line at the current time across all lanes.
  // Re-renders with the dashboard's 1s clock tick, so it tracks the real time.
  const nowH = today.getHours() + today.getMinutes() / 60;
  const showNow = nowH >= startH && nowH <= endH;
  const nowPct = pct(nowH);
  const nowLabel = `${(today.getHours() % 12) || 12}:${String(today.getMinutes()).padStart(2, '0')}${today.getHours() < 12 ? 'a' : 'p'}`;

  // Build calendar blocks for the You lane. Skip all-day events from the
  // hour-axis; they show up in the lane label as a count instead.
  const youBlocks: TimelineBlock[] = [];
  let allDayCount = 0;
  for (const ev of calendar.list) {
    if (ev.allDay) {
      allDayCount += 1;
      continue;
    }
    const sh = isoToHour(ev.start);
    const eh = isoToHour(ev.end);
    if (sh == null || eh == null) continue;
    if (eh <= startH || sh >= endH) continue;
    youBlocks.push({
      laneKey: 'you',
      label: ev.summary || '(untitled event)',
      hue: '#0EA5E9',
      startH: Math.max(startH, sh),
      endH: Math.min(endH, eh),
      source: 'event',
      href: ev.htmlLink ?? undefined,
    });
  }

  // Per-rascal task blocks. Tasks have due_at but not start/end — render
  // each as a 30-min marker at its due hour. Today only.
  const taskByAgent: Record<string, TimelineBlock[]> = {};
  for (const t of tasks.list) {
    if (!t.assigned_agent) continue;
    if (t.status === 'done') continue;
    if (!isToday(t.due_at)) continue;
    const sh = isoToHour(t.due_at!);
    if (sh == null) continue;
    if (sh < startH - 0.25 || sh > endH + 0.25) continue;
    const lane = taskByAgent[t.assigned_agent] ?? [];
    lane.push({
      laneKey: t.assigned_agent,
      label: t.title,
      hue: agentHueFromDashboard(t.assigned_agent),
      startH: Math.max(startH, sh - 0.25),
      endH: Math.min(endH, sh + 0.25),
      source: 'task',
    });
    taskByAgent[t.assigned_agent] = lane;
  }

  // Compose lane list: You (always), then each rascal that has tasks today.
  // Sort agents with tasks alphabetically for stable order.
  const agentLaneKeys = Object.keys(taskByAgent).sort();
  type Lane = { title: string; agent?: string; blocks: TimelineBlock[]; allDay?: number };
  const lanes: Lane[] = [
    { title: 'You', blocks: youBlocks, allDay: allDayCount },
    ...agentLaneKeys.map((handle) => {
      const r = rascals.list.find((x) => x.handle === handle);
      return {
        title: r?.displayName ?? handle,
        agent: handle,
        blocks: taskByAgent[handle],
      };
    }),
  ];

  const loading = !calendar.loaded || !tasks.loaded;
  const empty =
    calendar.loaded && tasks.loaded && lanes.length === 1 && lanes[0].blocks.length === 0 && !allDayCount;

  return (
    <Panel
      title="Today · Timeline (from Calendar)"
      icon={<Clock size={14} />}
      accent="linear-gradient(135deg, #7C3CFF 0%, #0EA5E9 100%)"
      className="flex-1"
      meta={
        <span className="vs-mono text-[10px]" style={{ color: '#9AA8C2' }} data-testid="timeline-meta">
          {loading
            ? 'LOADING…'
            : `${youBlocks.length} EVENTS · ${Object.values(taskByAgent).reduce((s, b) => s + b.length, 0)} TASKS`}
        </span>
      }
    >
      <div className="px-3.5 pt-2.5 pb-4 relative" data-testid="timeline-panel">
        {empty && (
          <div className="text-[12px] italic py-3" style={{ color: '#74849A' }}>
            No events or tasks scheduled in the {startH}–{endH}:00 window today.
          </div>
        )}
        {!empty && (
          <>
            <div className="flex relative h-4 ml-[110px]" style={{ color: '#74849A' }}>
              {hours.map((h) => (
                <div key={h} className="vs-mono flex-1 text-[10px]">
                  {h}:00
                </div>
              ))}
              {showNow && (
                <div
                  className="absolute -top-0.5 pointer-events-none"
                  style={{ left: `${nowPct}%`, transform: 'translateX(-50%)', zIndex: 6 }}
                  data-testid="timeline-now-label"
                >
                  <span
                    className="vs-mono text-[8px] leading-none px-1 py-[1px] rounded whitespace-nowrap"
                    style={{ background: '#FF5C5C', color: '#fff', boxShadow: '0 0 6px rgba(255,92,92,0.6)' }}
                  >
                    {nowLabel}
                  </span>
                </div>
              )}
            </div>
            {lanes.map((lane) => {
              const { packed, rowCount } = packBlocksIntoRows(lane.blocks);
              const rowHeight = 22; // px per row of blocks
              const rowGap = 3;
              const trackHeight = rowCount * rowHeight + Math.max(0, rowCount - 1) * rowGap;
              return (
              <div
                key={lane.agent ?? 'you'}
                className="flex items-center gap-2.5 relative py-1.5"
                data-timeline-lane={lane.agent ?? 'you'}
                data-row-count={rowCount}
              >
                <div className="w-[100px] flex items-center gap-2 min-w-0 self-start pt-1">
                  {lane.agent ? (
                    <AgentAvatar handle={lane.agent} displayName={lane.title} size={18} />
                  ) : (
                    <div
                      className="w-[18px] h-[18px] rounded-full"
                      style={{ background: 'linear-gradient(135deg, #7C3CFF 0%, #0EA5E9 100%)' }}
                    />
                  )}
                  <span className="text-[11px] truncate" style={{ color: '#F1F4FF' }}>
                    {lane.title}
                    {lane.allDay ? (
                      <span className="vs-mono ml-1 text-[9px]" style={{ color: '#74849A' }}>
                        +{lane.allDay}d
                      </span>
                    ) : null}
                  </span>
                </div>
                <div
                  className="flex-1 relative"
                  style={{
                    borderLeft: '1px solid rgba(216,228,240,0.95)',
                    height: trackHeight,
                  }}
                >
                  {hours.map((_, i) => (
                    <div
                      key={i}
                      className="absolute top-0 bottom-0"
                      style={{
                        left: `${(i / hours.length) * 100}%`,
                        borderLeft: '1px dashed rgba(14,165,233,0.12)',
                      }}
                    />
                  ))}
                  {showNow && (
                    <div
                      className="absolute top-0 bottom-0 pointer-events-none"
                      style={{
                        left: `${nowPct}%`,
                        borderLeft: '2px solid #FF5C5C',
                        boxShadow: '0 0 6px rgba(255,92,92,0.6)',
                      }}
                      data-testid="timeline-now-line"
                    />
                  )}
                  {packed.map((b, bi) => {
                    const Tag: React.ElementType = b.href ? 'a' : 'div';
                    return (
                    <Tag
                      key={`${lane.agent ?? 'you'}-${bi}`}
                      {...(b.href ? { href: b.href, target: '_blank', rel: 'noreferrer' } : {})}
                      title={b.href ? `${b.label} — open in Google Calendar` : b.label}
                      className="absolute flex items-center gap-1.5 rounded-md text-[10.5px] px-2 truncate"
                      style={{
                        top: b.row * (rowHeight + rowGap),
                        height: rowHeight,
                        left: `${pct(b.startH)}%`,
                        width: `calc(${Math.max(2, pct(b.endH) - pct(b.startH))}% - 2px)`,
                        background: `linear-gradient(135deg, ${b.hue}44, ${b.hue}22)`,
                        border: `1px solid ${b.hue}88`,
                        color: '#F1F4FF',
                        boxShadow: `inset 0 0 12px ${b.hue}22`,
                        cursor: b.href ? 'pointer' : 'default',
                        textDecoration: 'none',
                      }}
                    >
                      <span
                        className="w-1 h-1 rounded-full flex-shrink-0"
                        style={{ background: b.hue, boxShadow: `0 0 6px ${b.hue}` }}
                      />
                      <span className="truncate">{b.label}</span>
                    </Tag>
                    );
                  })}
                </div>
              </div>
              );
            })}
          </>
        )}
      </div>
    </Panel>
  );
}

/** Pull rascal hue without re-importing — uses the public helper from AgentAvatar. */
function agentHueFromDashboard(handle: string): string {
  // Keep this small to avoid a full import cycle; the hue-cycle here mirrors
  // the THEMES table in components/AgentAvatar.tsx for the 10 known rascals.
  // Falls back to a neutral grey for unknowns.
  const map: Record<string, string> = {
    alfalfa: '#7C3CFF', buckwheat: '#FF8A3D', butch: '#ff5c5c',
    darla: '#FF4D8D', froggy: '#20B26B', petey: '#a07060',
    porky: '#ff8c5c', spanky: '#0EA5E9', stymie: '#d6b6ff',
    wheezer: '#9d8bff',
  };
  return map[handle] ?? '#9AA8C2';
}

