function useDashWidgets(): { enabled: Set<WidgetId>; toggle: (id: WidgetId) => void } {
  // Migration (see migratedEnabled): drop ids no longer in the catalog (e.g.
  // the retired 'meta'/'facebook' tiles) and force-add the brand-new tiles so
  // existing users actually see them.
  const [enabled, setEnabled] = useState<Set<WidgetId>>(migratedEnabled);
  const toggle = (id: WidgetId) =>
    setEnabled((prev) => {
      const next = new Set(prev);
      if (next.has(id)) next.delete(id); else next.add(id);
      try { localStorage.setItem(WIDGETS_KEY, JSON.stringify([...next])); } catch { /* ignore */ }
      return next;
    });
  return { enabled, toggle };
}

