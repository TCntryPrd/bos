          setState({ list: unread, loaded: true });
        })
        .catch(() => { if (!cancelled) setState((s) => ({ ...s, loaded: true })); }); // keep last on poll error
    };
    load();
    const id = window.setInterval(load, 15_000); // Poll every 15s
    return () => { cancelled = true; window.clearInterval(id); };
  }, []);
  return state;
}

