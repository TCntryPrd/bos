// ──────────────────────────────────────────────────────────────────────
// Auth helper (v1.6.1)
// ──────────────────────────────────────────────────────────────────────
//
// Every Dashboard panel reads from auth-gated API endpoints. Before
// v1.6.1 a 401 silently fell through to "loaded with empty data",
// which made an expired session look identical to "you legitimately
// have no rascals/tasks/etc." Per the screenshot Kevin shared on
// 2026-04-25, that produced an entirely zeroed Dashboard for an
// authenticated user whose token had simply gone stale.
//
// authedFetch() centralises the header injection and dispatches a
// window event the moment any request comes back 401. useAuthHealth()
// listens for the event and returns true once it fires; the Dashboard
// uses that flag to render a top-of-page "session expired" banner
// rather than zeros. Hooks themselves keep returning empty arrays on
// non-200 so they can render a sane loading→empty path independent of
// the auth state.

const AUTH_EXPIRED_EVENT = 'boss-auth-expired';

async function authedFetch(input: RequestInfo, init?: RequestInit): Promise<Response> {
  const token = localStorage.getItem('boss_token') ?? '';
  const headers = new Headers(init?.headers);
  if (token) headers.set('Authorization', `Bearer ${token}`);
  const res = await fetch(input, { ...init, headers });
  if (res.status === 401) {
    try { window.dispatchEvent(new Event(AUTH_EXPIRED_EVENT)); } catch { /* SSR safety */ }
  }
  return res;
}

/**
 * DASHBOARD_POLL_MS — how often tiles silently re-fetch in the background.
 * Tiles update in place (React reconciles new data into the existing DOM), so
 * there is no remount, no flicker, no scroll jump — the screen is not disrupted.
 */
const DASHBOARD_POLL_MS = 45_000;

/**
 * usePolledJson — fetch a JSON endpoint on mount and every `ms` thereafter,
 * swapping the data in place. Crucially it KEEPS the last good data on a
 * transient poll error (only surfaces `error` if the very first load failed),
 * so a momentary blip never blanks a tile that already has data.
 */
function usePolledJson<T>(
  url: string,
  ms = DASHBOARD_POLL_MS,
): { data: T | null; error: boolean; loaded: boolean } {
  const [data, setData] = useState<T | null>(null);
  const [error, setError] = useState(false);
  const [loaded, setLoaded] = useState(false);
  const okRef = useRef(false);
  useEffect(() => {
    let alive = true;
    const load = () => {
      const token = localStorage.getItem('boss_token') ?? '';
      fetch(url, { headers: token ? { Authorization: `Bearer ${token}` } : {} })
        .then((r) => (r.ok ? r.json() : Promise.reject(new Error(String(r.status)))))
        .then((d) => {
          if (!alive) return;
          setData(d as T);
          setError(false);
          setLoaded(true);
          okRef.current = true;
        })
        .catch(() => {
          if (!alive) return;
          setLoaded(true);
          if (!okRef.current) setError(true); // keep last good data after first success
        });
    };
    load();
    const iv = setInterval(load, ms);
    return () => { alive = false; clearInterval(iv); };
  }, [url, ms]);
  return { data, error, loaded };
}

/**
 * usePoll — run an arbitrary loader on mount and every `ms`, for panels whose
 * fetch + parsing don't fit usePolledJson. The loader may return a cleanup that
 * runs before each re-poll and on unmount (e.g. a `cancelled` flag). Loaders
 * should keep the last good state on error so a transient poll doesn't blank.
 */
function usePoll(load: () => void | (() => void), ms = DASHBOARD_POLL_MS): void {
  useEffect(() => {
    let cleanup: void | (() => void);
    const run = () => {
      if (typeof cleanup === 'function') cleanup();
      cleanup = load();
    };
    run();
    const iv = setInterval(run, ms);
    return () => { clearInterval(iv); if (typeof cleanup === 'function') cleanup(); };
    // eslint-disable-next-line react-hooks/exhaustive-deps
  }, []);
}

function useAuthHealth(): { expired: boolean } {
  const [expired, setExpired] = useState(false);
  useEffect(() => {
    const onExpired = () => setExpired(true);
    window.addEventListener(AUTH_EXPIRED_EVENT, onExpired);
    return () => window.removeEventListener(AUTH_EXPIRED_EVENT, onExpired);
  }, []);
  return { expired };
}

