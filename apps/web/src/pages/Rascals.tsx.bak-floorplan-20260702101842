            <div className="vs-mono mt-1 truncate text-[10.5px] text-[#51615b]">{agent.handle}</div>
          </div>
          <ArrowUpRight className="mt-1 h-4 w-4 flex-shrink-0 text-[#51615b] opacity-55 transition group-hover:translate-x-0.5 group-hover:-translate-y-0.5 group-hover:opacity-90" />
