          </div>
          <div className="flex flex-col justify-between rounded-md border border-white/48 bg-white/58 p-2 shadow-lg">
            <span
              className="vs-mono rounded-full border px-2 py-1 text-center text-[8.5px] uppercase tracking-[0.16em]"
