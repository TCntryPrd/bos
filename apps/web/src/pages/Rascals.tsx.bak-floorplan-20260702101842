      <div className="absolute bottom-0 left-0 right-0 h-[92px] border-t border-white/24 bg-gradient-to-b from-[#8b6941]/94 to-[#50391f]/98" aria-hidden />
      <div className="absolute inset-y-3 left-3 w-px bg-white/42" aria-hidden />
      <div className="absolute inset-y-3 right-3 w-px bg-white/42" aria-hidden />
      <div
        className="absolute left-4 right-4 top-0 h-px"
        style={{ background: `linear-gradient(90deg, transparent, ${hue}aa, transparent)` }}
        aria-hidden
      />

      <div className="relative z-10 flex min-h-[268px] flex-col p-3">
        <div className="flex items-start gap-3">
