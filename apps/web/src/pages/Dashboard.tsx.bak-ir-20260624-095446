}

type SparkKind = 'rise' | 'wave' | 'split';

function Spark({ kind = 'rise', color = '#7C3CFF' }: { kind?: SparkKind; color?: string }) {
  const paths: Record<SparkKind, string> = {
    rise:  'M1 18 L8 14 L14 15 L22 9 L30 11 L38 4 L46 6',
    wave:  'M1 12 C5 4, 10 20, 14 12 S22 4, 26 12 S34 20, 38 12 S46 4, 48 12',
    split: 'M1 12 L10 12 L14 6 L18 18 L22 8 L26 14 L30 12 L46 12',
  };
  const id = `sg-${kind}-${color.replace('#', '')}`;
  return (
    <svg width="48" height="22" viewBox="0 0 48 22" fill="none" className="block">
      <defs>
        <linearGradient id={id} x1="0" x2="1">
          <stop offset="0" stopColor={color} stopOpacity="0.3" />
          <stop offset="1" stopColor={color} />
        </linearGradient>
      </defs>
      <path d={paths[kind]} stroke={`url(#${id})`} strokeWidth="1.3" fill="none" strokeLinecap="round" strokeLinejoin="round" />
    </svg>
  );
}

