function SocialFeedPanel() {
  // pollKey is folded into the URL so a successful post re-keys usePolledJson
  // (its effect depends on `url`), forcing an immediate fresh fetch.
  const [pollKey, setPollKey] = useState(0);
  const url = pollKey === 0 ? 'api/meta/social' : `api/meta/social?r=${pollKey}`;
  const { data, loaded } = usePolledJson<SocialData>(url, 30_000);
  const fb = data?.facebook ?? null;
  const ig = data?.instagram ?? null;
  const fbPosts = fb?.posts ?? [];
  const igMedia = ig?.media ?? [];

  const [draft, setDraft] = useState('');
  const [posting, setPosting] = useState(false);
  const [notice, setNotice] = useState<{ kind: 'ok' | 'err'; text: string } | null>(null);

  const submit = async () => {
    const message = draft.trim();
    if (!message || posting) return;
    if (!window.confirm('Publish to the Facebook Page now?')) return;
    setPosting(true);
    setNotice(null);
    try {
      const token = localStorage.getItem('boss_token') ?? '';
      const headers = new Headers({ 'Content-Type': 'application/json' });
      if (token) headers.set('Authorization', `Bearer ${token}`);
      const res = await fetch('api/meta/fb/post', {
        method: 'POST',
        headers,
        body: JSON.stringify({ message }),
      });
      const body = await res.json().catch(() => null);
      if (res.ok && body?.ok) {
        setDraft('');
        setNotice({ kind: 'ok', text: 'Posted ✓' });
        setPollKey((k) => k + 1); // trigger a re-poll of the feed
      } else if (res.status === 409) {
        setNotice({ kind: 'err', text: 'Facebook Page not connected — link it in Connections.' });
      } else {
        setNotice({ kind: 'err', text: body?.error || `Post failed (${res.status})` });
