{
  "uid": "boss-system-health",
  "title": "IR Custom AIOS — System Health",
  "description": "Overall health status of all IR Custom AIOS v2 services: API, Worker, Postgres, Redis, Weaviate, STT.",
  "tags": ["boss", "health"],
  "timezone": "browser",
  "refresh": "30s",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "templating": { "list": [] },
  "annotations": { "list": [] },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "API — Up",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"boss-api\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Worker — Up",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"boss-worker\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Postgres — Up",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"postgres\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Redis — Up",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"redis\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Weaviate — Up",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"weaviate\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 6,
      "type": "stat",
      "title": "STT — Up",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "options": {
        "reduceOptions": { "calcs": ["lastNotNull"] },
        "colorMode": "background",
        "graphMode": "none",
        "textMode": "auto"
      },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "up{job=\"boss-stt\"}",
        "legendFormat": ""
      }]
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Host CPU Usage %",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": 0, "color": "green" }, { "value": 70, "color": "yellow" }, { "value": 90, "color": "red" }]
          }
        }
      },
      "options": { "tooltip": { "mode": "multi" } },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 - (avg by (instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[2m])) * 100)",
        "legendFormat": "CPU"
      }]
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Host Memory Used %",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": 0, "color": "green" }, { "value": 75, "color": "yellow" }, { "value": 90, "color": "red" }]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 * (1 - (node_memory_MemAvailable_bytes / node_memory_MemTotal_bytes))",
        "legendFormat": "Memory"
      }]
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Disk Used % (root)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": 0, "color": "green" }, { "value": 75, "color": "yellow" }, { "value": 90, "color": "red" }]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "100 * (1 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"}))",
        "legendFormat": "Disk /"
      }]
    },
    {
      "id": 13,
      "type": "timeseries",
      "title": "Postgres Active Connections",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [{ "value": 0, "color": "green" }, { "value": 50, "color": "yellow" }, { "value": 90, "color": "red" }]
          }
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "pg_stat_activity_count{state=\"active\"}",
        "legendFormat": "Active connections"
      }]
    },
    {
      "id": 14,
      "type": "timeseries",
      "title": "Redis Memory Used (MB)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "decmbytes"
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "redis_memory_used_bytes / 1024 / 1024",
        "legendFormat": "Redis used MB"
      }]
    },
    {
      "id": 15,
      "type": "timeseries",
      "title": "API Request Rate (req/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        }
      },
      "targets": [{
        "datasource": "Prometheus",
        "expr": "sum(rate(http_requests_total{job=\"boss-api\"}[2m]))",
        "legendFormat": "Requests/s"
      }]
    }
  ]
}
